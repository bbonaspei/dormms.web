@model DormMS.Web.Models.Payment
@{
    ViewData["Title"] = "Record New Collection";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="stat-card-new shadow-lg p-5 border-0 bg-white" style="border-radius: 40px;">
                <div class="d-flex align-items-center gap-3 mb-5">
                    <div class="icon-box-pro bg-primary-subtle text-primary"><i class="bi bi-cash-coin fs-2"></i></div>
                    <div>
                        <h2 class="fw-900 m-0 text-dark">Register Payment</h2>
                        <p class="text-muted small fw-bold">Enter the details for student fee collection.</p>
                    </div>
                </div>

                <form asp-action="Create" method="post" class="custom-premium-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-floating mb-4">
                        <select asp-for="studentId" class="form-select rounded-pill px-4" asp-items="ViewBag.studentId" style="height: 60px;"></select>
                        <label asp-for="studentId" class="ms-2">Target Student</label>
                    </div>

                    <div class="form-floating mb-4">
                        <select name="feeId" class="form-select rounded-pill px-4" asp-items="ViewBag.feeId" style="height: 60px;"></select>
                        <label class="ms-2">Associated Fee / Billing Item</label>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="amount" class="form-control rounded-pill px-4" placeholder="0.00" style="height: 60px;" />
                                <label asp-for="amount" class="ms-2">Execution Amount (TL)</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="paymentMethod" class="form-select rounded-pill px-4" style="height: 60px;">
                                    <option value="Credit Card">Credit Card</option>
                                    <option value="Bank Transfer">Bank Transfer</option>
                                    <option value="Cash">Physical Cash</option>
                                    <option value="Online">Online Portal</option>
                                </select>
                                <label asp-for="paymentMethod" class="ms-2">Instrument</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-5">
                        <input name="status" value="Completed" type="hidden" />
                        <select asp-for="status" class="form-select rounded-pill px-4" style="height: 60px;">
                             <option value="Completed">Success (Finalized)</option>
                             <option value="Pending">Pending (Processing)</option>
                        </select>
                        <label asp-for="status" class="ms-2">Transaction Status</label>
                    </div>

                    <div class="d-flex gap-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-light rounded-pill px-5 py-3 fw-bold flex-grow-1">Abort</a>
                        <button type="submit" class="btn btn-vibrant-cyan rounded-pill px-5 py-3 fw-bold flex-grow-2">Execute Transaction</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .icon-box-pro { width: 70px; height: 70px; border-radius: 20px; display: flex; align-items: center; justify-content: center; }
    .bg-primary-subtle { background-color: #eef2ff !important; }
    .flex-grow-2 { flex: 2; }
</style>




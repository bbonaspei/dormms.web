@model IEnumerable<DormMS.Web.Models.Room>

@{
    ViewData["Title"] = "Room Archives";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid px-4 mt-5">

    <div class="row align-items-center mb-5">
        <div class="col-md-8">
            <h1 style="color: #312e81; font-weight: 900; font-size: 2.8rem; letter-spacing: -2px; margin-bottom: 0;">
                Room <span style="color: #6366f1;">Archives.</span>
            </h1>
            <p class="text-muted fw-bold mt-2">Manage and restore previously decommissioned residential units.</p>
        </div>
        <div class="col-md-4 text-end">
            
            <a asp-action="Index" class="btn-back-premium text-decoration-none shadow-sm d-inline-flex align-items-center gap-2">
                <i class="bi bi-arrow-left"></i> BACK TO INVENTORY
            </a>
        </div>
    </div>

    <div class="row g-5">
        @if (!Model.Any())
        {
            
            <div class="col-12 text-center py-5">
                <div class="icon-box mx-auto mb-4 shadow-sm" style="width: 80px; height: 80px; background: rgba(99, 102, 241, 0.1); color: #6366f1; font-size: 40px; border-radius: 20px; display:flex; align-items:center; justify-content:center;">
                    <i class="bi bi-archive"></i>
                </div>
                <h4 class="text-dark fw-bold">The Archive is Empty</h4>
                <p class="text-muted small fw-bold">All residential units are currently in active inventory.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="room-card-vibrant p-4 h-100 shadow-sm border-0" style="opacity: 0.95; background: #fcfcfc !important;">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="icon-box" style="width: 45px; height: 45px; background: #f1f5f9; color: #64748b; border-radius: 12px; display:flex; align-items:center; justify-content:center;">
                                <i class="bi bi-archive-fill"></i>
                            </div>
                            <span class="badge-inactive" style="background: rgba(100, 116, 139, 0.1); color: #64748b;">Archived</span>
                        </div>

                        <div class="mb-4">
                            <h3 class="fw-900 text-dark mb-1">Room @item.roomNumber</h3>
                            <span class="text-muted small fw-bold text-uppercase" style="letter-spacing: 1px;">
                                @item.Building?.buildingName | @item.RoomType?.typeName
                            </span>
                        </div>

                        <div class="occupancy-container mb-4" style="background: rgba(100, 116, 139, 0.05); padding: 12px; border-radius: 15px;">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="small fw-bold text-secondary">LAST STATE</span>
                                <span class="fw-bold small text-muted">@item.currentOccupancy / @item.capacity</span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-auto">
                            
                            <form id="restoreForm-@item.id" asp-action="Restore" asp-route-id="@item.id" method="post" style="width: 20%;">
                                @Html.AntiForgeryToken()
                                <button type="button" class="btn-card-delete-mini w-100"
                                        style="background: rgba(16, 185, 129, 0.1) !important; color: #10b981 !important; border:none; height:46px; border-radius:12px; transition:0.3s;"
                                        onclick="confirmRestore(@item.id)" title="Restore Room">
                                    <i class="bi bi-arrow-counterclockwise"></i>
                                </button>
                            </form>

                            <form id="deleteForm-@item.id" asp-action="Delete" asp-route-id="@item.id" method="post" style="width: 20%;">
                                @Html.AntiForgeryToken()
                                <button type="button" class="btn-card-delete-mini w-100"
                                        style="background: rgba(244, 63, 94, 0.1) !important; color: #f43f5e !important; border:none; height:46px; border-radius:12px; transition:0.3s;"
                                        onclick="confirmDelete(@item.id)" title="Delete Permanently">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </form>

                            <a asp-action="Details" asp-route-id="@item.id" class="btn-card-details-wide flex-grow-1 d-flex align-items-center justify-content-center gap-2 text-decoration-none"
                               style="background: #f1f5f9; color: #6366f1; border-radius: 12px; font-weight: 700; height: 46px;">
                                <i class="bi bi-eye-fill"></i> View
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
    function confirmRestore(id) {
        Swal.fire({
            title: 'Restore this unit?',
            text: "The room will be moved back to the active inventory.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#10b981',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Yes, restore it!',
            background: '#ffffff',
            borderRadius: '20px'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('restoreForm-' + id).submit();
            }
        })
    }

    function confirmDelete(id) {
        Swal.fire({
            title: 'Delete Permanently?',
            text: "This room will be removed from the database records forever.",
            icon: 'error',
            showCancelButton: true,
            confirmButtonColor: '#f43f5e',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Yes, delete forever!',
            background: '#ffffff',
            borderRadius: '20px'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('deleteForm-' + id).submit();
            }
        })
    }
</script>



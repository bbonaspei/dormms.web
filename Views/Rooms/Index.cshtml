@model IEnumerable<DormMS.Web.Models.Room>

@{
    ViewData["Title"] = "Room Inventory";
}

<!-- Başlık Bölümü -->
<div class="row align-items-center page-header-area px-2">
    <div class="col-md-8 text-start">
        <h1 style="color: #312e81; font-weight: 900; font-size: 2.2rem; letter-spacing: -1.5px;">
            Residential <span style="color: #6366f1;">Inventory.</span>
        </h1>
        <p class="text-muted small fw-medium">Advanced monitoring and unit status management.</p>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Create" class="btn-premium text-decoration-none">
            <i class="bi bi-plus-lg"></i> Register Unit
        </a>
    </div>
</div>

<!-- Arama Çubuğu -->
<div class="row mb-5 px-2">
    <div class="col-12">
        <div class="search-wrapper-new">
            <i class="bi bi-search" style="color: #6366f1;"></i>
            <input type="text" class="search-input-new" placeholder="Filter by room, floor or unit status...">
        </div>
    </div>
</div>

<!-- Oda Kartları Listesi -->
<div class="row g-4 px-2">
    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted fw-bold">No units found in the database. Please register a unit.</p>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="room-card-vibrant">
                    <!-- Üst Kısım -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div style="width:40px; height:40px; background:rgba(99, 102, 241, 0.1); border-radius:10px; display:flex; align-items:center; justify-content:center; color:#6366f1;">
                            <i class="bi bi-door-closed-fill"></i>
                        </div>
                        <span class="status-badge-premium">@item.status</span>
                    </div>

                    <!-- Orta Kısım -->
                    <div class="mb-4">
                        <h4 class="fw-bold mb-1" style="color: #1e293b;">Room @item.roomNumber</h4>
                        <p class="text-muted small fw-bold text-uppercase">Floor @item.floorNumber • @item.RoomType?.typeName</p>
                    </div>

                    <!-- Doluluk Alanı -->
                    <div class="occupancy-glass-card">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <span class="small fw-bold text-muted">RESIDENCY</span>
                            <span style="font-weight: 900; color: #6366f1;">@item.currentOccupancy/@item.capacity</span>
                        </div>
                        <div style="height: 10px; background: #eef2f7; border-radius: 20px; overflow: hidden;">
                            <div class="progress-premium-bar" style="width: @((item.currentOccupancy * 100) / (item.capacity == 0 ? 1 : item.capacity))%;"></div>
                        </div>
                    </div>

                    <!-- Kira Bedeli -->
                    <div class="lease-fee-badge">
                        <span class="small fw-bold text-muted text-uppercase" style="font-size: 10px;">Lease Fee</span>
                        <span class="lease-fee-amount">$@item.RoomType?.basePrice</span>
                    </div>

                    <!-- Aksiyon Butonları (Yeni Hover Efektli) -->
                    <div class="d-flex gap-2 mt-auto">
                        <a asp-action="Edit" asp-route-id="@item.id" class="btn-card-edit w-100 text-decoration-none">Details</a>
                        <button class="btn-card-delete border-0"><i class="bi bi-trash3-fill"></i></button>
                    </div>
                </div>
            </div>
        }
    }
</div>
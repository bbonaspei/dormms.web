@model IEnumerable<DormMS.Web.Models.Allocation>

@{
    ViewData["Title"] = "Active Placements";
}

<!-- Sayfa Başlığı ve Yeni Atama Butonu -->
<div class="row align-items-center page-header-area px-2">
    <div class="col-md-8 text-start">
        <h1 style="color: #312e81; font-weight: 900; font-size: 2.2rem; letter-spacing: -1.5px;">
            Active <span style="color: #6366f1;">Placements.</span>
        </h1>
        <p class="text-muted small fw-medium">Live mapping of students to dormitory units and residential history.</p>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Create" class="btn-premium text-decoration-none">
            <i class="bi bi-plus-lg me-2"></i> New Allocation
        </a>
    </div>
</div>

<!-- ATAMALAR LİSTESİ (KARTLI YAPI) -->
<div class="row g-4 px-2">
    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="p-5 bg-white shadow-sm rounded-4 d-inline-block">
                <i class="bi bi-key display-1 text-muted opacity-25"></i>
                <p class="mt-3 fw-bold text-muted">No active allocations found.</p>
                <a asp-action="Create" class="btn btn-link text-primary text-decoration-none">Initialize first placement</a>
            </div>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="room-card-vibrant">
                    <!-- Üst İkon ve Durum -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div style="width:40px; height:40px; background:rgba(99, 102, 241, 0.1); border-radius:10px; display:flex; align-items:center; justify-content:center; color:#6366f1;">
                            <i class="bi bi-person-check-fill"></i>
                        </div>
                        <span class="status-badge-premium" style="background:rgba(16, 185, 129, 0.1); color:#10b981;">
                            @item.status
                        </span>
                    </div>

                    <!-- Öğrenci ve Oda Bilgisi -->
                    <div class="mb-4">
                        <h4 class="fw-bold mb-1" style="color: #1e293b;">@item.Student?.User?.firstName @item.Student?.User?.lastName</h4>
                        <p class="text-muted small fw-bold text-uppercase">Assigned to: Room @item.Room?.roomNumber</p>
                    </div>

                    <!-- Tarih ve Detay Alanı (Glassy Style) -->
                    <div class="occupancy-glass-card">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="small fw-bold text-muted">START DATE</span>
                            <span class="small fw-bold" style="color:#6366f1;">@item.startDate.ToShortDateString()</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small fw-bold text-muted">END DATE</span>
                            <span class="small fw-bold" style="color:#a855f7;">@(item.endDate.HasValue? item.endDate.Value.ToShortDateString() : "Unlimited")</span>
                        </div>
                    </div>

                    <!-- Aksiyonlar -->
                    <div class="d-flex gap-2 mt-auto">
                        <a href="#" class="btn-card-edit w-100 text-decoration-none">View Details</a>
                        <button class="btn-card-delete border-0"><i class="bi bi-box-arrow-right"></i></button>
                    </div>
                </div>
            </div>
        }
    }
</div>
@model IEnumerable<DormMS.Web.Models.Allocation>

@{
    ViewData["Title"] = "Active Placements";
}

<div class="container-fluid px-4 mt-5">
    
    <div class="row align-items-center mb-5">
        <div class="col-md-8 text-start">
            <h1 style="color: #312e81; font-weight: 900; font-size: 2.8rem; letter-spacing: -2px; margin: 0;">
                Active <span style="color: #6366f1;">Placements.</span>
            </h1>
            <p class="text-muted fw-bold mt-2">Live mapping of students to dormitory units and residential history.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn-premium text-decoration-none d-flex align-items-center gap-2 float-end">
                <i class="bi bi-plus-lg"></i> New Allocation
            </a>
        </div>
    </div>

    <div class="row g-5 px-2">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="p-5 bg-white shadow-sm rounded-4 d-inline-block border">
                    <i class="bi bi-key display-1 text-muted opacity-25"></i>
                    <p class="mt-3 fw-bold text-muted">No active allocations found in the registry.</p>
                    <a asp-action="Create" class="btn btn-link text-primary fw-bold text-decoration-none">Initialize first placement</a>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="room-card-vibrant p-4 h-100 shadow-sm border-0">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="icon-box icon-blue" style="width: 45px; height: 45px; border-radius: 12px;">
                                <i class="bi bi-person-check-fill"></i>
                            </div>
                            <span class="@(item.status == "Confirmed" ? "badge-confirmed" : item.status == "Pending" ? "badge-pending" : "badge-completed")">
                                @item.status
                            </span>
                        </div>

                        <div class="mb-4">
                            <h3 class="fw-900 text-dark mb-1" style="font-size: 1.4rem;">@item.Student?.User?.firstName @item.Student?.User?.lastName</h3>
                            <div class="badge bg-light text-primary border fw-bold px-3 py-2" style="font-size: 10px; letter-spacing: 1px; border-radius: 10px;">
                                <i class="bi bi-door-closed-fill me-1"></i> ROOM @item.Room?.roomNumber
                            </div>
                        </div>

                        <div class="occupancy-glass-card p-3 mb-4" style="background: rgba(99, 102, 241, 0.03); border-radius: 20px;">
                            <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2" style="border-color: rgba(0,0,0,0.05) !important;">
                                <span class="small fw-800 text-muted" style="font-size: 10px;">CHECK-IN</span>
                                <span class="small fw-bold text-dark">@item.startDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center pt-1">
                                <span class="small fw-800 text-muted" style="font-size: 10px;">EXPECTED END</span>
                                <span class="small fw-bold text-primary">@(item.endDate.HasValue? item.endDate.Value.ToString("MMM dd, yyyy") : "Unlimited")</span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-auto">
                            
                            <form id="terminateForm-@item.id" asp-action="Terminate" asp-route-id="@item.id" method="post" style="width: 25%;">
                                @Html.AntiForgeryToken()
                                <button type="button" class="btn-card-delete-mini w-100"
                                        onclick="confirmCheckOut(@item.id)" title="Terminate / Check-out">
                                    <i class="bi bi-box-arrow-right"></i>
                                </button>
                            </form>

                            <a asp-controller="Students" asp-action="Details" asp-route-id="@item.studentId" class="btn-card-details-wide flex-grow-1 text-decoration-none">
                                <i class="bi bi-person-badge-fill"></i> View Profile
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    
    .fw-800 {
        font-weight: 800;
    }

    .fw-900 {
        font-weight: 900;
    }
</style>

<script>
    function confirmCheckOut(id) {
        Swal.fire({
            title: 'Terminate Placement?',
            text: "This will officially check-out the student. The room capacity will be updated.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#f43f5e',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Yes, check-out!',
            background: '#ffffff',
            borderRadius: '20px'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('terminateForm-' + id).submit();
            }
        })
    }
</script>



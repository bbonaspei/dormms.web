@model IEnumerable<DormMS.Web.Models.RoomType>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DormMS - Future Living</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css?v=@DateTime.Now.Ticks">
    <link rel="stylesheet" href="~/css/layout.css">
    <link rel="stylesheet" href="~/css/components.css?v=@DateTime.Now.Ticks">
    <style>
        
        .room-slider-container {
            display: flex !important;
            gap: 30px !important;
            padding: 30px 10px !important;
            overflow-x: auto !important;
            scroll-snap-type: x mandatory !important;
        }
        .room-card-premium {
            flex: 0 0 320px !important;
            min-width: 320px !important;
            height: 480px !important;
            scroll-snap-align: start !important;
            background: white !important;
            border-radius: 30px !important;
            overflow: hidden !important;
        }
        .room-image-frame {
            width: 100% !important;
            height: 240px !important;
            overflow: hidden !important;
        }
        .room-image-frame img {
            width: 100% !important;
            height: 100% !important;
            object-fit: cover !important;
        }
    </style>
</head>
<body class="login-page-body">
    <div class="mesh-bg">
        <div class="blob blob-1"></div><div class="blob blob-2"></div><div class="blob blob-3"></div>
    </div>

    <nav class="container mt-4 py-3 px-4 d-flex justify-content-between align-items-center"
         style="background: rgba(255,255,255,0.6); backdrop-filter: blur(20px); border-radius: 100px; border: 1px solid white; position: sticky; top: 20px; z-index: 1000;">
        <div class="brand-wrapper">
            <div class="logo-icon" style="background: var(--primary-grad); color: white;"><i class="bi bi-grid-3x3-gap-fill"></i></div>
            <div class="brand-text" style="color: #1e293b !important; font-weight: 800;">DormMS</div>
        </div>
        <div class="d-none d-lg-flex gap-5">
            <a href="#rooms" class="nav-link-landing text-decoration-none fw-bold">ROOMS</a>
            <a href="#location" class="nav-link-landing text-decoration-none fw-bold">LOCATION</a>
            <a href="#" class="nav-link-landing text-decoration-none fw-bold">SUPPORT</a>
        </div>
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="Account" asp-action="Login" class="btn-vibrant-cyan text-decoration-none" style="padding: 10px 35px !important; border-radius: 50px;">Login</a>
        </div>
    </nav>

    <section class="container py-5 mt-5">
        <div class="row align-items-center">
            <div class="col-lg-6 text-start">
                <h1 style="font-size: 5.5rem; font-weight: 950; line-height: 0.9; letter-spacing: -4px; color: #1e293b;">
                    Better <span style="color: var(--indigo);">Spaces.</span><br />
                    Better <span style="background: var(--primary-grad); -webkit-background-clip: text; color: transparent;">Living.</span>
                </h1>
                <p class="mt-4 fs-5 text-muted" style="max-width: 480px;">The ultimate management ecosystem for Ostim Technical University residents.</p>
                <div class="mt-5">
                    <a asp-controller="Account" asp-action="Login" class="btn-vibrant-cyan text-decoration-none px-5 py-3 fs-5">Get Started Now</a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-mockup-container">
                    <div class="floating-card-premium">
                        <img src="~/images/dorm.jpg" class="w-100 h-100" style="object-fit:cover; border-radius:30px;" onerror="this.src='https://images.unsplash.com/photo-1555854817-5a22834a5078?q=80'">
                        <div style="position: absolute; bottom: 25px; left: 25px; background: white; padding: 12px 20px; border-radius: 15px; font-weight: 800; color: #1e293b; box-shadow: 0 10px 30px rgba(0,0,0,0.1);"><i class="bi bi-geo-alt-fill text-danger me-2"></i> Ostim Tech Campus</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="rooms" class="container-fluid py-5 mt-5">
        <div class="container"><h2 class="fw-black display-5 mb-5" style="letter-spacing: -2px; color: #1e293b;">Room <span style="color: var(--indigo);">Showcase.</span></h2></div>

        <div class="room-slider-wrapper">
            <div class="slider-nav-btn btn-prev" onclick="scrollSlider(-400)"><i class="bi bi-chevron-left"></i></div>
            <div class="slider-nav-btn btn-next" onclick="scrollSlider(400)"><i class="bi bi-chevron-right"></i></div>
            <div class="room-slider-container" id="roomSlider">

                @if (Model != null && Model.Any())
                {
                    int counter = 0;
                    foreach (var type in Model)
                    {
                        counter++;
                        var roomTitle = type.typeName ?? "Standard Room";
                        var roomPrice = (int)type.basePrice;
                        var roomLabel = type.capacity + " PERSON" + (type.capacity > 1 ? "S" : "");

                        <div class="room-card-premium">
                            
                            <div class="room-image-frame position-relative" onclick="openGallery('room' + @counter, 3)" style="height: 240px; overflow: hidden;">
                                <img src="/images/rooms/room@(counter > 5 ? 1 : counter)/1.jpg" class="w-100 h-100" style="object-fit: cover !important; display: block;" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?q=80'">
                                <div class="image-overlay-pro"><i class="bi bi-images me-2"></i> View Photos</div>
                            </div>
                            <div class="room-card-body-premium">
                                <div>
                                    <h4 class="fw-900 text-dark mb-1">@roomTitle</h4>
                                    <div class="d-flex gap-1 mb-2">
                                        <span class="room-feature-tag">WiFi</span>
                                        <span class="room-feature-tag">@(type.hasAirConditioner ? "A/C" : "Desk")</span>
                                        @if(type.hasBathroom) { <span class="room-feature-tag">Bathroom</span> }
                                    </div>
                                    <p class="small text-muted mb-0">@(type.description ?? "Premium living space.")</p>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-auto border-top pt-3">
                                    <span class="fw-900 fs-4 text-primary">@roomPrice TL</span>
                                    <span class="badge rounded-pill bg-dark py-1 px-3" style="font-size: 10px;">@roomLabel</span>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    @for (int i = 1; i <= 3; i++)
                    {
                        <div class="room-card-premium opacity-50">
                             <div class="room-image-frame"><img src="https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?q=80"></div>
                             <div class="p-4"><h4 class="fw-900">Standard Room</h4><p>Maintenance in progress...</p></div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <section id="location" class="container py-5 mt-5 mb-5">
        <div class="contact-card-premium" style="background: #1e293b; border-radius: 45px; padding: 60px;">
            <div class="row align-items-center">
                <div class="col-md-5 text-white">
                    <h2 class="fw-black display-6 mb-4">Visit Our <span style="color: var(--purple);">Campus.</span></h2>
                    <p class="opacity-75 mb-5">Find us at Ostim Technical University, Ankara.</p>
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:50px; height:50px; background:rgba(255,255,255,0.1); border-radius:15px; display:flex; align-items:center; justify-content:center; color:var(--cyan);"><i class="bi bi-geo-alt-fill fs-4"></i></div>
                        <span class="fw-bold">Ankara, Ostim Technical University</span>
                    </div>
                </div>
                <div class="col-md-7 mt-5 mt-lg-0">
                    <div class="map-container-pro">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3055.8545!2d32.7483!3d39.9485!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14d349372e6b12a3%3A0xc3910540d5885f09!2sOstim%20Teknik%20%C3%9cniversitesi!5e0!3m2!1str!2str!4v1712662000000" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="modal fade" id="galleryModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content bg-transparent border-0">
                <div class="modal-body p-0 position-relative">
                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-4 z-3" data-bs-dismiss="modal"></button>
                    <button class="gallery-nav-btn btn-gallery-prev" onclick="changeImage(-1)"><i class="bi bi-chevron-left"></i></button>
                    <button class="gallery-nav-btn btn-gallery-next" onclick="changeImage(1)"><i class="bi bi-chevron-right"></i></button>
                    <div class="text-center"><img id="modalImage" src="" class="img-fluid rounded-5 shadow-lg" style="max-height: 85vh; width: 100%; object-fit: contain;"></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let folder = ""; let idx = 1; let total = 0;
        function openGallery(f, c) {
            folder = f; total = c; idx = 1;
            updateModal();
            new bootstrap.Modal(document.getElementById('galleryModal')).show();
        }
        function changeImage(s) {
            idx += s;
            if (idx < 1) idx = total;
            if (idx > total) idx = 1;
            updateModal();
        }
        function updateModal() {

            document.getElementById('modalImage').src = "/images/rooms/" + folder + "/" + idx + ".jpg";
        }
        function scrollSlider(a) { document.getElementById('roomSlider').scrollBy({ left: a, behavior: 'smooth' }); }
    </script>
</body>
</html>




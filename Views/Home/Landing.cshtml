@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>DormMS - Future Living</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css?v=@DateTime.Now.Ticks">
    <link rel="stylesheet" href="~/css/layout.css">
</head>
<body class="login-page-body">
    <div class="mesh-bg">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
    </div>

    <!-- Floating Navbar -->
    <nav class="container mt-4 py-3 px-4 d-flex justify-content-between align-items-center"
         style="background: rgba(255,255,255,0.4); backdrop-filter: blur(20px); border-radius: 100px; border: 1px solid rgba(255,255,255,0.4); position: sticky; top: 20px; z-index: 1000;">
        <div class="brand-wrapper">
            <div class="logo-icon" style="background: var(--primary-grad); color: white;"><i class="bi bi-grid-3x3-gap-fill"></i></div>
            <div class="brand-text" style="color: #1e293b !important; font-weight: 800;">DormMS</div>
        </div>
        <div class="d-none d-lg-flex gap-2">
            <a href="#rooms" class="nav-link-landing text-decoration-none">ROOMS & FEATURES</a>
            <a href="#location" class="nav-link-landing text-decoration-none">LOCATION</a>
            <a href="#" class="nav-link-landing text-decoration-none">SUPPORT</a>
        </div>
        <a asp-controller="Account" asp-action="Login" class="btn-vibrant-cyan text-decoration-none" style="padding: 10px 30px !important;">Login</a>
    </nav>

    <!-- HERO SECTION -->
    <section class="container py-5 mt-5">
        <div class="row align-items-center">
            <div class="col-lg-6 text-start">
                <h1 style="font-size: 5.5rem; font-weight: 950; line-height: 0.9; letter-spacing: -4px; color: #1e293b;">
                    Better <span style="color: var(--indigo);">Spaces.</span><br />
                    Better <span style="background: var(--primary-grad); -webkit-background-clip: text; color: transparent;">Living.</span>
                </h1>
                <p class="mt-4 fs-5 text-muted" style="max-width: 480px; line-height: 1.6;">
                    The ultimate management ecosystem for modern student housing. Experience premium residential services and automated comfort.
                </p>
                <div class="mt-5 d-flex gap-3">
                    <a asp-controller="Account" asp-action="Login" class="btn-vibrant-cyan text-decoration-none">Get Started Now</a>
                    <button class="btn-ghost-premium">Take a Tour</button>
                </div>
            </div>

            <!-- Right Side: 3D UI Preview (Fixed & Steady) -->
            <div class="col-lg-6 d-none d-lg-block">
                <div class="floating-ui-mockup">
                    <!-- id ve data-bs-ride kısımlarına dikkat -->
                    <div id="mockupCarousel" class="carousel slide carousel-fade h-100" data-bs-ride="carousel">
                        <div class="carousel-inner h-100">

                            <!-- Slide 1 (Dorm Main) -->
                            <div class="carousel-item active h-100">
                                <img src="~/images/dorm.jpg" class="mockup-image-fill" alt="Dormitory" onerror="this.src='https://images.unsplash.com/photo-1545324418-f1d3ac1573b4?q=80&w=1000'">
                            </div>

                            <!-- Slide 2 (Room Preview) -->
                            <div class="carousel-item h-100">
                                <img src="~/images/room1.jpg" class="mockup-image-fill" alt="Room 1" onerror="this.src='https://images.unsplash.com/photo-1555854817-5a22834a5078?q=80&w=1000'">
                            </div>

                            <!-- Slide 3 (Lounge or Social) -->
                            <div class="carousel-item h-100">
                                <img src="https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?q=80&w=1000" class="mockup-image-fill" alt="Social Area">
                            </div>

                        </div>

                        <!-- Etiket (Resmin üzerine biner ve milim oynamaz) -->
                        <div style="position: absolute; bottom: 20px; left: 20px; background: white; padding: 10px 20px; border-radius: 12px; font-weight: 800; color: #1e293b; z-index: 20; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                            <i class="bi bi-geo-alt-fill text-danger me-2"></i> Main Campus Block
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ROOM SHOWCASE (HORIZONTAL SLIDER WITH 5 CATEGORIES) -->
    <section id="rooms" class="container-fluid py-5 mt-5">
        <div class="container">
            <h2 class="fw-black display-5 mb-5" style="letter-spacing: -2px; color: #1e293b;">Room <span style="color: var(--indigo);">Showcase.</span></h2>
        </div>

        <div class="room-slider-wrapper">
            <!-- Navigasyon Okları -->
            <div class="slider-nav-btn btn-prev" onclick="scrollSlider(-360)"><i class="bi bi-chevron-left"></i></div>
            <div class="slider-nav-btn btn-next" onclick="scrollSlider(360)"><i class="bi bi-chevron-right"></i></div>

            <div class="room-slider-container" id="roomSlider">

                <!-- ROOM 1 -->
                <div class="room-card-premium">
                    <div class="room-image-frame" onclick="openGallery('/images/room1.jpg')">
                        <img src="~/images/room1.jpg" onerror="this.src='https://images.unsplash.com/photo-1555854817-5a22834a5078?q=80'">
                    </div>
                    <div class="room-card-body-premium">
                        <div>
                            <h3 class="fw-bold" style="color: #1e293b; font-size: 1.8rem;">Executive Single</h3>
                            <p class="text-muted">High-speed Wi-Fi, private workspace, and premium ergonomic furniture.</p>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-black fs-3" style="color: var(--indigo);">$850<small class="fs-6 opacity-50">/mo</small></span>
                            <span class="badge rounded-pill bg-dark py-2 px-3">1 PERSON</span>
                        </div>
                    </div>
                </div>

                <!-- ROOM 2 -->
                <div class="room-card-premium">
                    <div class="room-image-frame" onclick="openGallery('/images/room2.jpg')">
                        <img src="~/images/room2.jpg" onerror="this.src='https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf?q=80'">
                    </div>
                    <div class="room-card-body-premium">
                        <div>
                            <h3 class="fw-bold" style="color: #1e293b; font-size: 1.8rem;">Collaborative Twin</h3>
                            <p class="text-muted">Spacious shared studio designed for duo-living and collaboration.</p>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-black fs-3" style="color: var(--indigo);">$600<small class="fs-6 opacity-50">/mo</small></span>
                            <span class="badge rounded-pill bg-info-subtle text-info-emphasis py-2 px-3">2 PERSONS</span>
                        </div>
                    </div>
                </div>

                <!-- ROOM 3 -->
                <div class="room-card-premium">
                    <div class="room-image-frame" onclick="openGallery('/images/room3.jpg')">
                        <img src="~/images/room3.jpg" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?q=80'">
                    </div>
                    <div class="room-card-body-premium">
                        <div>
                            <h3 class="fw-bold" style="color: #1e293b; font-size: 1.8rem;">Triple Comfort</h3>
                            <p class="text-muted">Affordable shared space with dedicated private storage units.</p>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-black fs-3" style="color: var(--indigo);">$500<small class="fs-6 opacity-50">/mo</small></span>
                            <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis py-2 px-3">3 PERSONS</span>
                        </div>
                    </div>
                </div>

                <!-- ROOM 4 -->
                <div class="room-card-premium">
                    <div class="room-image-frame" onclick="openGallery('https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?q=80')">
                        <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?q=80">
                    </div>
                    <div class="room-card-body-premium">
                        <div>
                            <h3 class="fw-bold" style="color: #1e293b; font-size: 1.8rem;">Elite Quad</h3>
                            <p class="text-muted">The ultimate penthouse experience for large student groups.</p>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-black fs-3" style="color: var(--indigo);">$450<small class="fs-6 opacity-50">/mo</small></span>
                            <span class="badge rounded-pill bg-dark py-2 px-3">4 PERSONS</span>
                        </div>
                    </div>
                </div>

                <!-- ROOM 5 -->
                <div class="room-card-premium">
                    <div class="room-image-frame" onclick="openGallery('https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?q=80')">
                        <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?q=80">
                    </div>
                    <div class="room-card-body-premium">
                        <div>
                            <h3 class="fw-bold" style="color: #1e293b; font-size: 1.8rem;">Studio Loft</h3>
                            <p class="text-muted">High-ceiling studio for independent living with smart amenities.</p>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-black fs-3" style="color: var(--indigo);">$1500<small class="fs-6 opacity-50">/mo</small></span>
                            <span class="badge rounded-pill" style="background:var(--cyan); color:#000; padding:10px 20px;">STUDIO</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- CONTACT SECTION (Aynen Kalabilir) -->
    <section id="location" class="container py-5 mt-5 mb-5">
        <div class="contact-card-premium">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h2 class="fw-black display-6 mb-4">Visit Our <span style="color: var(--purple);">Campus.</span></h2>
                    <p style="color: rgba(255,255,255,0.6); margin-bottom: 40px;">Ready to see it in person? Our concierge is available for live tours daily.</p>
                    <div class="d-flex flex-column gap-4">
                        <div class="d-flex align-items-center gap-3">
                            <div style="width:45px; height:45px; background:rgba(255,255,255,0.1); border-radius:12px; display:flex; align-items:center; justify-content:center; color:var(--cyan);">
                                <i class="bi bi-geo-alt-fill"></i>
                            </div>
                            <span class="fw-bold">123 Education Boulevard, Istanbul, TR</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mt-5 mt-md-0 text-center">
                    <div style="width:100%; height:300px; background:rgba(255,255,255,0.05); border-radius:30px; border: 2px dashed rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center;">
                        <span class="fw-black opacity-25">INTERACTIVE MAP VIEW</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- GALLERY MODAL -->
    <div class="modal fade" id="galleryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content modal-content-premium p-2">
                <img id="modalImage" src="" class="gallery-img-full">
                <button type="button" class="btn-close p-3 position-absolute top-0 end-0 bg-white" data-bs-dismiss="modal"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function openGallery(imgSrc) { document.getElementById('modalImage').src = imgSrc; new bootstrap.Modal(document.getElementById('galleryModal')).show(); }
                // Landing.cshtml en altındaki script kısmında:
        function scrollSlider(amount) {
            // Kart genişliği 320px + Gap 40px = 360px civarı bir kaydırma idealdir
            document.getElementById('roomSlider').scrollBy({
                left: amount, // Buradaki amount değerini HTML içindeki onclick'ten alıyor
                behavior: 'smooth'
            });
        }
    </script>
</body>
</html>
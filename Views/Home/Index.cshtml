<div class="row align-items-center page-header-area px-2">
    <div class="col-md-8 text-start">
        <h1 style="color: #312e81; font-weight: 900; font-size: 2.5rem; letter-spacing: -2px;">Dashboard.</h1>
        <p class="fw-medium text-muted">Enterprise operations and dormitory resource analytics.</p>
    </div>
    <div class="col-md-4 text-end">
        <button class="btn-premium"><i class="bi bi-plus-lg"></i> Quick Action</button>
    </div>
</div>

<div class="row g-4 mb-5 px-2">
    <!-- Stat 1 -->
    <div class="col-md-3">
        <div class="stat-card-new">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="stat-title-premium">Capacity</p>
                    <div class="d-flex align-items-baseline"><span class="stat-value-premium">@ViewBag.TotalRooms</span><span class="stat-unit-label">Units</span></div>
                </div>
                <div class="icon-box icon-blue"><i class="bi bi-building"></i></div>
            </div>
            <div style="height: 4px; width: 40px; background: #6366f1; border-radius: 10px; margin-top: 15px; opacity: 0.3;"></div>
        </div>
    </div>
    <!-- Stat 2 -->
    <div class="col-md-3">
        <div class="stat-card-new">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="stat-title-premium">Tenancy</p>
                    <div class="d-flex align-items-baseline"><span class="stat-value-premium">@ViewBag.OccupiedRooms</span><span class="stat-unit-label">Active</span></div>
                </div>
                <div class="icon-box icon-green"><i class="bi bi-people"></i></div>
            </div>
            <div style="height: 4px; width: 40px; background: #10b981; border-radius: 10px; margin-top: 15px; opacity: 0.3;"></div>
        </div>
    </div>
    <!-- Stat 3 -->
    <div class="col-md-3">
        <div class="stat-card-new">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="stat-title-premium">Revenue</p>
                    <div class="d-flex align-items-baseline"><span class="stat-value-premium">$0.00</span></div>
                </div>
                <div class="icon-box icon-orange"><i class="bi bi-currency-dollar"></i></div>
            </div>
            <div style="height: 4px; width: 40px; background: #f59e0b; border-radius: 10px; margin-top: 15px; opacity: 0.3;"></div>
        </div>
    </div>
    <!-- Stat 4 -->
    <div class="col-md-3">
        <div class="stat-card-new">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="stat-title-premium">Backlog</p>
                    <div class="d-flex align-items-baseline"><span class="stat-value-premium">0</span><span class="stat-unit-label">Pending</span></div>
                </div>
                <div class="icon-box icon-red"><i class="bi bi-tools"></i></div>
            </div>
            <div style="height: 4px; width: 40px; background: #f43f5e; border-radius: 10px; margin-top: 15px; opacity: 0.3;"></div>
        </div>
    </div>
</div>

<div class="row g-4 px-2">
    <div class="col-lg-8"><div class="stat-card-new" style="min-height: 280px; display: flex; flex-direction: column; justify-content: center;"><h5 class="fw-bold mb-4">System Status</h5><div class="text-center py-4"><i class="bi bi-shield-check fs-1 text-success opacity-25"></i><p class="text-muted mt-3 fw-medium">All dormitory infrastructure modules are healthy.</p></div></div></div>
    <div class="col-lg-4">
        <div class="stat-card-new">
            <h5 class="fw-bold mb-4">Portal</h5>
            <div class="d-flex flex-column gap-1">
                <!-- Manage Buildings eklendi -->
                <a asp-controller="Buildings" asp-action="Index" class="portal-item text-decoration-none">
                    <i class="bi bi-houses"></i> <span>Manage Buildings</span>
                </a>
                <a asp-controller="Rooms" asp-action="Index" class="portal-item text-decoration-none">
                    <i class="bi bi-door-open"></i> <span>Manage Inventory</span>
                </a>
                <a href="#" class="portal-item text-decoration-none">
                    <i class="bi bi-person-plus"></i> <span>Enroll Student</span>
                </a>
                <a href="#" class="portal-item text-decoration-none">
                    <i class="bi bi-wallet2"></i> <span>Financial Ledger</span>
                </a>
                <!-- Index.cshtml Portal kısmına ekle -->
                <a asp-controller="RoomTypes" asp-action="Index" class="portal-item text-decoration-none">
                    <i class="bi bi-tags"></i> <span>Manage Classifications</span>
                </a>
            </div>
        </div>
    </div>
</div>
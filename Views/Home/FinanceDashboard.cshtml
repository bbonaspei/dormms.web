@{
    ViewData["Title"] = "Finance Intelligence Hub";
    var revenueData = ViewBag.RevenueData as IEnumerable<decimal> ?? new List<decimal> { 0, 0, 0, 0, 0, 0, 0 };
}

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<div class="container-fluid px-4 mt-4">
    <div class="mb-5 d-flex justify-content-between align-items-end">
        <div>
            <div class="d-flex align-items-center gap-3 mb-2">
                <span class="badge bg-success-subtle text-success rounded-pill px-3 py-1 fw-bold" style="font-size: 11px; letter-spacing: 0.5px;">
                    <i class="bi bi-shield-check me-1"></i> ACCOUNTING SYSTEM ONLINE
                </span>
                <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-1 fw-bold" style="font-size: 11px; letter-spacing: 0.5px;">
                    <i class="bi bi-cpu me-1"></i> INTEL HUB V2.0
                </span>
            </div>
            <h1 style="color: #312e81 !important; font-weight: 900; font-size: 3.5rem; letter-spacing: -3px; margin-bottom: 0; line-height: 1;">
                Finance <span style="color: #6366f1;">Center.</span>
            </h1>
            <p class="text-muted fw-800 mt-2">Institutional fiscal oversight & automated revenue tracking.</p>
        </div>
        <form asp-action="SyncAllFinances" method="post">
            <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="bi bi-arrow-repeat me-1"></i> Sync All Resident Ledgers
            </button>
        </form>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
             <div class="stat-card-new p-4 text-center shadow-sm h-100 border-0" style="background: linear-gradient(135deg, #6366f1 0%, #4338ca 100%) !important; color: #ffffff !important; border-radius: 24px; cursor: pointer; transition: transform 0.2s; position: relative;">
                 <i class="bi bi-plus-circle-fill" style="font-size: 3rem; display: block; margin-bottom: 5px; color: white !important;"></i>
                 <div class="fw-900" style="font-size: 1.1rem; color: white !important;">REGISTER PAYMENT</div>
                 <p class="small mb-0" style="color: rgba(255,255,255,0.8) !important;">Submit new collection</p>
                 <a asp-controller="Payments" asp-action="Create" class="stretched-link"></a>
             </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card-new shadow-sm p-4 border-0 bg-white" style="border-radius: 24px; height: 100%; border-bottom: 5px solid #ef4444 !important; background: white !important;">
                <div class="text-danger fw-800 mb-1" style="font-size: 0.7rem; letter-spacing: 1px; text-uppercase;">Outstanding Revenue</div>
                <h2 class="fw-900 m-0 text-dark" style="font-size: 2.2rem; letter-spacing: -1.5px;">@(((decimal?)(ViewBag.UnpaidAmount ?? 0m))?.ToString("N2")) TL</h2>
                <div class="small text-muted fw-bold mt-1">Pending collection</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card-new shadow-sm p-4 border-0 bg-white" style="border-radius: 24px; height: 100%; border-bottom: 5px solid #10b981 !important; background: white !important;">
                <div class="text-success fw-800 mb-1" style="font-size: 0.7rem; letter-spacing: 1px; text-uppercase;">Active Accounts</div>
                <h2 class="fw-900 m-0 text-dark" style="font-size: 2.2rem; letter-spacing: -1.5px;">@(ViewBag.ActiveStudents ?? 0)</h2>
                <div class="small text-muted fw-bold mt-1">Residents with active lease</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card-new shadow-sm p-4 border-0 bg-white" style="border-radius: 24px; height: 100%; border-bottom: 5px solid #3b82f6 !important; background: white !important;">
                <div class="text-primary fw-800 mb-1" style="font-size: 0.7rem; letter-spacing: 1px; text-uppercase;">Weekly Velocity</div>
                <h2 class="fw-900 m-0 text-dark" style="font-size: 2.2rem; letter-spacing: -1.5px;">@(revenueData.Sum().ToString("N2")) TL</h2>
                <div class="small text-muted fw-bold mt-1">Success rate: 100%</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        
        <div class="col-lg-8">
            <div class="stat-card-new shadow-sm p-4 border-0 bg-white" style="border-radius: 30px; background: white !important; height: 100%;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-900 m-0 text-dark"><i class="bi bi-activity me-2 text-primary"></i>Financial Flow Analytics</h5>
                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 fw-bold">Live 7-Day Performance</span>
                </div>
                <div id="financeRevenueChart" style="min-height: 400px; width: 100%;"></div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="stat-card-new shadow-sm p-4 border-0 bg-white" style="border-radius: 30px; background: white !important; height: 100%;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-900 m-0 text-dark"><i class="bi bi-clock-history me-2 text-indigo"></i>Recent Activity</h5>
                    <a asp-controller="Payments" asp-action="Index" class="small fw-bold text-decoration-none">Full Audit &rarr;</a>
                </div>
                <div class="activity-list">
                    @if (ViewBag.RecentPayments != null && ((List<DormMS.Web.Models.Payment>)ViewBag.RecentPayments).Any())
                    {
                        foreach (var payment in (List<DormMS.Web.Models.Payment>)ViewBag.RecentPayments)
                        {
                            <div class="d-flex align-items-center justify-content-between p-3 mb-2 rounded-3" style="background: #f8fafc; border-left: 4px solid #6366f1;">
                                <div style="flex:1">
                                    <div class="fw-900 text-dark small">@(payment.Student?.User?.firstName) @(payment.Student?.User?.lastName)</div>
                                    <div class="text-muted" style="font-size: 10px;">@payment.paymentDate.ToString("dd MMM, HH:mm")</div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-900 text-success small">+ @payment.amount.ToString("N0") TL</div>
                                    <div class="badge bg-indigo-subtle text-indigo p-1" style="font-size: 8px;">@payment.paymentMethod</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted display-4"></i>
                            <p class="text-muted small mt-2">No collection records found.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-indigo-subtle { background-color: rgba(99, 102, 241, 0.1) !important; }
    .bg-success-subtle { background-color: rgba(16, 185, 129, 0.1) !important; }
    .bg-primary-subtle { background-color: rgba(99, 102, 241, 0.1) !important; }
    .text-indigo { color: #6366f1 !important; }
    .fw-800 { font-weight: 800 !important; }
    .fw-900 { font-weight: 900 !important; }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        var options = {
            series: [{ name: 'Revenue', data: @Html.Raw(Json.Serialize(revenueData)) }],
            chart: { type: 'area', height: 400, toolbar: { show: false } },
            stroke: { curve: 'smooth', width: 4 },
            colors: ['#6366f1'],
            xaxis: { categories: @Html.Raw(Json.Serialize(ViewBag.RevenueLabels)) },
            yaxis: { labels: { formatter: function(val) { return val.toLocaleString() + " TL"; } } }
        };
        var chart = new ApexCharts(document.querySelector("#financeRevenueChart"), options);
        chart.render();
    });
</script>





@{
    ViewData["Title"] = "Operations Center";
    var allTasks = ViewBag.AllTasks as IEnumerable<DormMS.Web.Models.MaintenanceRequest>;
    int currentUserId = ViewBag.CurrentUserId;
    var myTasks = allTasks?.Where(t => t.assignedTo == currentUserId).ToList();
    var pendingMyTasks = myTasks?.Count(t => t.status != "Completed") ?? 0;
}

<div class="container-fluid px-4 mt-5">
    
    <div class="row mb-5 align-items-center">
        <div class="col-md-8">
            <h1 style="color: #312e81; font-weight: 900; font-size: 3rem; letter-spacing: -2.5px; margin-bottom: 5px;">
                Operations <span style="color: #6366f1;">Hub.</span>
            </h1>
            <p class="text-muted fw-bold">System Status: <span class="text-success"><i class="bi bi-circle-fill me-1" style="font-size: 10px;"></i> Operational</span> | Welcome back, @ViewBag.StaffName</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="d-inline-flex align-items-center gap-2 p-2 bg-glass-dark rounded-pill border px-3 shadow-sm">
                <i class="bi bi-calendar3 text-primary"></i>
                <span class="small fw-900 text-dark">@DateTime.Now.ToString("MMM dd, yyyy")</span>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stat-card-new alert-border-blue d-flex flex-column h-100 p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="icon-box icon-blue">
                        <i class="bi bi-person-check-fill"></i>
                    </div>
                    @if (pendingMyTasks > 0)
                    {
                        <span class="badge bg-danger rounded-pill px-2">Action Required</span>
                    }
                </div>
                <h5 class="stat-title-premium mb-1">My Active Jobs</h5>
                <div class="stat-value-premium" style="font-size: 2.2rem;">@pendingMyTasks</div>
                <p class="text-muted small mt-2 m-0">Tasks currently assigned to your profile.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card-new alert-border-orange d-flex flex-column h-100 p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="icon-box icon-orange">
                        <i class="bi bi-list-task"></i>
                    </div>
                </div>
                <h5 class="stat-title-premium mb-1">Facility Backlog</h5>
                <div class="stat-value-premium" style="font-size: 2.2rem;">@(allTasks?.Count() ?? 0)</div>
                <p class="text-muted small mt-2 m-0">Total pending requests across the facility.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card-new alert-border-green d-flex flex-column h-100 p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="icon-box icon-green">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                </div>
                <h5 class="stat-title-premium mb-1">Efficiency Rating</h5>
                <div class="stat-value-premium" style="font-size: 2.2rem;">@ViewBag.EfficiencyRate<span class="stat-unit-label">%</span></div>
                <p class="text-muted small mt-2 m-0">Percentage of tasks completed on schedule.</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-lg-8">
            <div class="info-section-card shadow-sm border-0 h-100 bg-white p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-900 m-0"><i class="bi bi-tools me-2 text-primary"></i>My Priority Tasks</h5>
                    <a asp-controller="Maintenance" asp-action="Index" class="btn btn-sm btn-light rounded-pill px-3 fw-bold">Full Backlog &raquo;</a>
                </div>

                @if (myTasks == null || !myTasks.Any(t => t.status != "Completed"))
                {
                    <div class="text-center py-5 border rounded-4 bg-light border-dashed">
                        <i class="bi bi-check2-all display-4 text-success opacity-25"></i>
                        <p class="mt-3 fw-bold text-muted mb-0">Great job! All your assigned tasks are completed.</p>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var task in myTasks.Where(t => t.status != "Completed"))
                        {
                            <div class="col-md-6">
                                <div class="task-card-staff p-3 border rounded-4 shadow-sm h-100 d-flex flex-column" style="background: #f8fafc;">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="badge @(task.priority == "High" || task.priority == "Emergency" ? "bg-danger" : "bg-warning text-dark") rounded-pill" style="font-size: 9px; font-weight:900;">@task.priority?.ToUpper()</span>
                                        <span class="small text-muted fw-bold">@task.requestNumber</span>
                                    </div>
                                    <h6 class="fw-bold text-dark mb-1">Room @(task.Room?.roomNumber ?? "-")</h6>
                                    <p class="small text-muted text-truncate mb-3">@task.description</p>
                                    
                                    <div class="mt-auto pt-2 border-top d-flex justify-content-between align-items-center">
                                        <a asp-controller="Maintenance" asp-action="Details" asp-route-id="@task.id" class="small fw-bold text-decoration-none">Details &rarr;</a>
                                        <form asp-controller="Maintenance" asp-action="UpdateStatus" method="post" onsubmit="return confirm('Complete this task?');">
                                            <input type="hidden" name="requestId" value="@task.id" />
                                            <input type="hidden" name="newStatus" value="Completed" />
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 fw-bold" style="font-size: 11px;">Mark Done</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="info-section-card shadow-sm border-0 h-100 bg-glass-dark p-4">
                <h6 class="section-title-premium mb-4"><i class="bi bi-lightning-charge-fill text-warning"></i> Operational Tools</h6>
                
                <div class="portal-item text-decoration-none bg-white mb-3 shadow-sm" style="cursor:default;">
                    <div class="icon-box icon-blue" style="width: 40px; height: 40px;"><i class="bi bi-archive-fill"></i></div>
                    <div>
                        <a asp-controller="Maintenance" asp-action="Archive" class="d-block text-dark fw-bold text-decoration-none stretched-link">Knowledge Base</a>
                        <div class="small text-muted">View past repairs and solutions.</div>
                    </div>
                </div>

                <div class="portal-item text-decoration-none bg-white shadow-sm" style="cursor:default;">
                    <div class="icon-box icon-red" style="width: 40px; height: 40px;"><i class="bi bi-person-badge"></i></div>
                    <div>
                        <a asp-controller="Account" asp-action="MyProfile" class="d-block text-dark fw-bold text-decoration-none stretched-link">Operational ID</a>
                        <div class="small text-muted">View your profile and metrics.</div>
                    </div>
                </div>

                <div class="p-4 rounded-4 bg-white mt-5 border shadow-sm">
                    <h6 class="fw-900 small mb-2"><i class="bi bi-patch-check-fill text-primary"></i> Daily Tip</h6>
                    <p class="small text-muted m-0">Always document the completion of high-priority tasks with a photo in the details section for quality assurance.</p>
                </div>
            </div>
        </div>
    </div>
</div>




@model IEnumerable<DormMS.Web.Models.AuditLog>

<div class="row align-items-center page-header-area px-2">
    <div class="col-md-8 text-start">
        <h1 style="color: #312e81; font-weight: 900; font-size: 2.5rem; letter-spacing: -2px;">
            Audit <span style="color: #64748b;">Telemetry.</span>
        </h1>
        <p class="text-muted">Institutional activity tracking and system modification logs.</p>
    </div>
</div>

<div class="stat-card-new p-0 overflow-hidden" style="border:none !important;">
    <table class="table table-hover mb-0">
        <thead style="background: #f8fafc;">
            <tr class="small text-muted fw-bold">
                <th class="p-4">ACTION</th>
                <th class="p-4">ENTITY</th>
                <th class="p-4">IP ADDRESS</th>
                <th class="p-4">TIMESTAMP</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="p-4">
                        <span class="badge @(item.action == "DELETE" ? "badge-inactive" : "badge-active")" style="font-size:10px;">
                            @item.action
                        </span>
                    </td>
                    <td class="p-4 fw-bold text-dark">@item.entityType #@item.entityId</td>
                    <td class="p-4 text-muted small">@item.ipAddress</td>
                    <td class="p-4 text-muted">@item.createdAt.ToString("dd MMM, HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
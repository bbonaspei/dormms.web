@model IEnumerable<DormMS.Web.Models.AuditLog>

<div class="container-fluid px-4 mt-5">
    <!-- Sayfa Başlığı ve Özet İstatistikler -->
    <div class="row align-items-center mb-5">
        <div class="col-md-7">
            <h1 style="color: #312e81; font-weight: 900; font-size: 3rem; letter-spacing: -2.5px; margin: 0;">
                Security <span style="color: #6366f1;">Telemetry.</span>
            </h1>
            <p class="text-muted fw-bold mt-2">Real-time oversight of administrative operations and data integrity.</p>
        </div>

        <!-- Üst Mini Stats (Hocaya Şov Yapmalık Kısım) -->
        <div class="col-md-5 d-none d-lg-block">
            <div class="d-flex gap-3 justify-content-end">
                <div class="audit-mini-card shadow-sm">
                    <span class="info-label-pro">Total Events</span>
                    <span class="fw-900 text-dark fs-5">@Model.Count()</span>
                </div>
                <div class="audit-mini-card shadow-sm border-start border-4 border-success">
                    <span class="info-label-pro">New Records</span>
                    <span class="fw-900 text-success fs-5">@Model.Count(l => l.action == "CREATE")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtreleme ve Arama Barı (Profesyonel Görünüm İçin) -->
    <div class="search-wrapper-new mb-4 shadow-sm border-0 bg-white px-4 py-3">
        <div class="d-flex align-items-center gap-3 w-100">
            <i class="bi bi-filter-left fs-4 text-primary"></i>
            <input type="text" class="search-input-new w-100" placeholder="Filter by operator name, entity type or action...">
            <span class="badge bg-light text-muted border px-3 py-2 rounded-pill small fw-bold">Live Stream Active</span>
        </div>
    </div>

    <!-- Ana Tablo Alanı -->
    <div class="info-section-card p-0 overflow-hidden shadow-sm border-0 bg-white" style="border-radius: 30px;">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead style="background: #f8fafc; border-bottom: 2px solid #edf2f7;">
                    <tr class="small text-muted fw-900">
                        <th class="ps-5 py-4" style="letter-spacing: 1px;">OPERATOR / SYSTEM</th>
                        <th class="py-4" style="letter-spacing: 1px;">MODIFICATION TYPE</th>
                        <th class="py-4" style="letter-spacing: 1px;">TARGET ENTITY</th>
                        <th class="py-4" style="letter-spacing: 1px;">NETWORK GATEWAY</th>
                        <th class="pe-5 py-4 text-end" style="letter-spacing: 1px;">TIMESTAMP</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var log in Model)
                        {
                            <tr class="log-row-premium">
                                <td class="ps-5">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-main-wrapper shadow-sm" style="width:42px; height:42px; border-radius:14px; font-size:1rem; background:#fff; border:1px solid #edf2f7;">
                                            @(log.User?.firstName?[0] ?? 'S')
                                        </div>
                                        <div>
                                            <div class="fw-900 text-dark" style="font-size: 0.95rem;">@(log.User?.firstName ?? "System") @log.User?.lastName</div>
                                            <div class="text-muted" style="font-size: 10px; font-weight: 700;">ADMIN_ID: #@(log.userId ?? 0)</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="status-indicator @(log.action == "CREATE" ? "status-completed" : log.action == "DELETE" ? "status-pending" : "status-progress")" style="font-size: 10px; padding: 6px 16px;">
                                        <i class="bi @(log.action == "CREATE" ? "bi-plus-circle" : log.action == "DELETE" ? "bi-trash" : "bi-pencil") me-1"></i>
                                        @log.action
                                    </span>
                                </td>
                                <td>
                                    <div class="entity-pill shadow-sm">
                                        @{
                                            var icon = log.entityType switch
                                            {
                                                "Student" => "bi-people-fill",
                                                "Room" => "bi-door-open-fill",
                                                "Payment" => "bi-cash-stack",
                                                "Building" => "bi-building-fill",
                                                _ => "bi-database-fill"
                                            };
                                        }
                                        <i class="bi @icon"></i>
                                        @log.entityType
                                        <span class="text-muted opacity-50 ms-1" style="font-size: 10px;">#@log.entityId</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="ip-tag-pro">
                                        <i class="bi bi-broadcast me-1 small"></i> @(string.IsNullOrEmpty(log.ipAddress) ? "127.0.0.1" : log.ipAddress)
                                    </span>
                                </td>
                                <td class="pe-5 text-end">
                                    <div class="fw-900 text-dark small">@log.createdAt.ToString("dd MMM, yyyy")</div>
                                    <div class="text-muted fw-bold" style="font-size: 11px;">@log.createdAt.ToString("HH:mm:ss")</div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="opacity-25 mb-3">
                                    <i class="bi bi-shield-slash" style="font-size: 4rem;"></i>
                                </div>
                                <h5 class="text-muted fw-bold">Zero activities recorded in current session.</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<script>
    document.querySelector('.search-input-new').addEventListener('keyup', function (e) {
        let term = e.target.value.toLowerCase();
        let rows = document.querySelectorAll('tbody tr');

        rows.forEach(row => {
            let content = row.innerText.toLowerCase();
            row.style.display = content.includes(term) ? "" : "none";
        });
    });
</script>
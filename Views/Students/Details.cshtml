@model DormMS.Web.Models.Student
@{
    bool isAdmin = ViewBag.IsAdmin ?? false;
    var user = Model.User;
}

<div class="container-fluid px-5">
    <!-- Üst Gezinti -->
    <div class="page-header-area d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn-back-premium text-decoration-none">
            <i class="bi bi-arrow-left"></i> BACK TO DIRECTORY
        </a>
        <div class="d-flex gap-2">
            <button class="btn btn-light border-0 fw-bold" style="border-radius:12px; padding:10px 20px;">Export CV</button>
            @if (isAdmin)
            {
                <button class="btn-premium">Manage Access</button>
            }
        </div>
    </div>

    <!-- PROFİL KAPAĞI (MODERN TASARIM) -->
    <div class="stat-card-new p-0 mb-5 overflow-hidden" style="border:none !important;">
        <div style="height: 120px; background: var(--primary-grad); opacity: 0.8;"></div>
        <div class="px-5 pb-5" style="margin-top: -40px;">
            <div class="d-flex align-items-end gap-4">
                <div style="width: 120px; height: 120px; background: white; border-radius: 30px; border: 6px solid var(--bg-base); display: flex; align-items: center; justify-content: center; font-size: 45px; font-weight: 900; color: #6366f1; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                    @(user?.firstName?[0])
                </div>
                <div class="pb-2">
                    <h1 class="mb-1" style="color: #1e293b; font-weight: 900; font-size: 2.5rem;">@user?.firstName @user?.lastName</h1>
                    <span class="badge @(isAdmin ? "bg-primary" : "bg-success") rounded-pill px-3 py-2 fw-bold" style="font-size: 11px; letter-spacing: 1px;">
                        <i class="bi bi-patch-check-fill me-1"></i> @(isAdmin ? "ROOT ADMINISTRATOR" : "VERIFIED STUDENT")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-5">
        <!-- SOL KOLON: Detaylar -->
        <div class="col-lg-4">
            <div class="stat-card-new mb-4">
                <h6 class="stat-title-premium">Core Metadata</h6>
                <div class="d-flex flex-column gap-3 mt-4">
                    <div class="d-flex justify-content-between border-bottom pb-2">
                        <span class="text-muted small fw-bold">STUDENT ID</span>
                        <span class="fw-bold text-dark">#@Model.studentId</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom pb-2">
                        <span class="text-muted small fw-bold">EMAIL</span>
                        <span class="fw-bold text-dark">@user?.email</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom pb-2">
                        <span class="text-muted small fw-bold">INSTITUTION</span>
                        <span class="fw-bold text-dark">@Model.university</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small fw-bold">ALLOCATION</span>
                        <span class="fw-bold" style="color:var(--indigo);">Room @Model.Room?.roomNumber</span>
                    </div>
                </div>
            </div>

            @if (isAdmin)
            {
                <div class="stat-card-new" style="background: #f8fafc !important;">
                    <h6 class="stat-title-premium text-primary">Admin Control</h6>
                    <p class="small text-muted mb-4">You have full write-access to this profile's institutional records.</p>
                    <button class="btn btn-dark w-100 py-3 fw-bold" style="border-radius:14px;">Modify Global Record</button>
                </div>
            }
        </div>

        <!-- SAĞ KOLON: Dosyalar -->
        <div class="col-lg-8">
            <div class="stat-card-new">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-black m-0" style="color:#1e293b;">Digital Repository</h5>
                    <span class="text-muted small fw-bold text-uppercase">Section 6: Document Mgmt</span>
                </div>

                <div class="row g-3 mb-5">
                    @foreach (var doc in ViewBag.Documents as List<DormMS.Web.Models.StudentDocument>)
                    {
                        <div class="col-md-6">
                            <div class="p-3 rounded-4" style="background: #f8fafc; display:flex; justify-content:space-between; align-items:center; border: 1px solid #eef2f7;">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:40px; height:40px; background:white; border-radius:10px; display:flex; align-items:center; justify-content:center; color:#f43f5e; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </div>
                                    <div><div class="small fw-bold text-dark">@doc.documentType</div><small class="text-muted" style="font-size:10px;">@doc.documentName</small></div>
                                </div>
                                <a href="@doc.filePath" target="_blank" class="btn btn-sm btn-white shadow-sm fw-bold px-3">Open</a>
                            </div>
                        </div>
                    }
                </div>

                <!-- UPLOAD ZONE -->
                <div class="p-5 rounded-5 text-center" style="background: #fafbfc; border: 2px dashed #e2e8f0;">
                    <form asp-action="UploadDoc" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="studentId" value="@Model.id" />
                        <i class="bi bi-cloud-arrow-up display-4 text-muted opacity-25"></i>
                        <h6 class="fw-bold mt-3">Drop new documents here</h6>
                        <p class="small text-muted mb-4">PDF, JPG or PNG up to 10MB</p>
                        <div class="d-flex gap-2 justify-content-center">
                            <input type="file" name="file" class="form-control form-control-sm w-50" required />
                            <select name="docType" class="form-select form-select-sm w-25">
                                <option value="ID">ID Card</option>
                                <option value="Contract">Lease</option>
                            </select>
                        </div>
                        <button type="submit" class="btn-premium mt-4">Initialize Upload</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@model DormMS.Web.Models.Student

<div class="container-fluid px-5">
    <div class="mb-4 mt-4">
        <a asp-action="Index" class="btn-back-premium">
            <i class="bi bi-arrow-left"></i> BACK TO DIRECTORY
        </a>
    </div>

    <div class="text-center mb-5">
        <h1 style="color: #312e81; font-weight: 900; font-size: 3rem; letter-spacing: -2px;">
            Resident <span style="color: #10b981;">Enrollment.</span>
        </h1>
        <p class="text-muted fw-bold">Register a new student and configure their academic profile.</p>
    </div>

    <div class="stat-card-new p-5 shadow-sm" style="max-width: 1100px; margin: 0 auto; border-top: 5px solid #10b981;">
        <form asp-action="Create">
            <div class="row g-4 text-start">

                <!-- BÖLÜM 1: KİŞİSEL KİMLİK -->
                <div class="col-12"><h5 class="fw-900 border-bottom pb-2 text-dark"><i class="bi bi-person-vcard me-2"></i>Personal Identity</h5></div>

                <div class="col-md-4">
                    <label class="label-premium">First Name</label>
                    <input name="firstName" class="dorm-input-premium" placeholder="e.g. Melike" required />
                </div>
                <div class="col-md-4">
                    <label class="label-premium">Last Name</label>
                    <input name="lastName" class="dorm-input-premium" placeholder="e.g. Kuzey" required />
                </div>
                <div class="col-md-4">
                    <label class="label-premium">Nationality</label>
                    <input asp-for="nationality" class="dorm-input-premium" placeholder="e.g. Turkish" />
                </div>
                <div class="col-md-8">
                    <label class="label-premium">Email Address (Institutional)</label>
                    <input name="email" type="email" class="dorm-input-premium" placeholder="student@university.edu" required />
                </div>
                <div class="col-md-4">
                    <label class="label-premium">Gender</label>
                    <select asp-for="gender" class="dorm-input-premium">
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <!-- BÖLÜM 2: AKADEMİK PROFİL -->
                <div class="col-12 mt-5"><h5 class="fw-900 border-bottom pb-2 text-dark"><i class="bi bi-book me-2"></i>Academic Profile</h5></div>

                <div class="col-md-4">
                    <label class="label-premium">Student ID (Okul No)</label>
                    <input asp-for="studentId" class="dorm-input-premium" placeholder="230208000" required />
                </div>
                <div class="col-md-8">
                    <label class="label-premium">University Name</label>
                    <input asp-for="university" class="dorm-input-premium" placeholder="Ostim Technical University" />
                </div>
                <div class="col-md-8">
                    <label class="label-premium">Course / Department</label>
                    <input asp-for="course" class="dorm-input-premium" placeholder="Software Engineering" />
                </div>
                <div class="col-md-4">
                    <label class="label-premium">Current Year</label>
                    <select asp-for="yearOfStudy" class="dorm-input-premium">
                        <option value="1">1st Year</option>
                        <option value="2">2nd Year</option>
                        <option value="3">3rd Year</option>
                        <option value="4">4th Year</option>
                    </select>
                </div>

                <!-- BÖLÜM 3: ADRES VE ACİL DURUM -->
                <div class="col-12 mt-5"><h5 class="fw-900 border-bottom pb-2 text-dark"><i class="bi bi-geo-alt me-2"></i>Address & Emergency</h5></div>

                <div class="col-md-8">
                    <label class="label-premium">Home Address</label>
                    <input asp-for="address" class="dorm-input-premium" placeholder="Street, Avenue, No..." />
                </div>
                <div class="col-md-4">
                    <label class="label-premium">City</label>
                    <input asp-for="city" class="dorm-input-premium" placeholder="Ankara" />
                </div>
                <div class="col-md-4">
                    <label class="label-premium">Emergency Contact Name</label>
                    <input asp-for="emergencyContactName" class="dorm-input-premium" />
                </div>
                <div class="col-md-4">
                    <label class="label-premium">Relationship</label>
                    <input asp-for="emergencyContactRelationship" class="dorm-input-premium" placeholder="e.g. Father" />
                </div>
                <div class="col-md-4">
                    <label class="label-premium">Emergency Phone</label>
                    <input asp-for="emergencyContactPhone" class="dorm-input-premium" />
                </div>

            </div>

            <!-- BUTONLAR -->
            <div class="d-flex justify-content-end align-items-center mt-5 pt-4 border-top gap-3">
                <a asp-action="Index" class="btn-discard-premium">CANCEL</a>
                <button type="submit" class="btn-premium px-5" style="background:linear-gradient(135deg, #10b981 0%, #14b8a6 100%) !important;">
                    <i class="bi bi-check2-all me-2"></i> Complete Registration
                </button>
            </div>
        </form>
    </div>
</div>
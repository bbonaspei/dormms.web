@model DormMS.Web.Models.Fee

@{
    ViewData["Title"] = "Create Fee Category";
}

<div class="container mt-5">
    
    <div class="mb-4">
        <a asp-action="Index" class="btn-back-premium shadow-sm text-decoration-none">
            <i class="bi bi-arrow-left"></i> BACK TO STRUCTURE
        </a>
    </div>

    <div class="form-card-premium shadow-sm border-top border-5 border-primary">
        <h2 class="fw-900 text-dark mb-4" style="letter-spacing:-1px;">
            New Fee <span style="color:#6366f1;">Definition.</span>
        </h2>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-4">
                
                <div class="col-md-8">
                    <div class="input-wrapper-premium">
                        <label class="label-premium">Fee Identifier / Name</label>
                        <input asp-for="feeName" class="dorm-input-premium" placeholder="e.g. Monthly Rent" required />
                        <span asp-validation-for="feeName" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="input-wrapper-premium">
                        <label class="label-premium">Standard Rate (TL)</label>
                        <input asp-for="amount" type="number" step="0.01" class="dorm-input-premium" required />
                        <span asp-validation-for="amount" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="input-wrapper-premium">
                        <label class="label-premium">Institutional Category</label>
                        <select asp-for="feeCategory" class="dorm-input-premium">
                            <option value="Housing">Housing (Rent)</option>
                            <option value="Utilities">Utilities (Electricity/Water/Internet)</option>
                            <option value="Security">Security Deposit</option>
                            <option value="Penalty">Late Payment Penalties</option>
                            <option value="Service">Additional Services (Gym/Social)</option>
                        </select>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="input-wrapper-premium">
                        <label class="label-premium">Billing Cycle</label>
                        <select asp-for="isRecurring" class="dorm-input-premium">
                            <option value="true">Recurring (Monthly)</option>
                            <option value="false">One-Time (Unique)</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 mt-5 pt-4 border-top">
                <button type="submit" class="btn-premium flex-grow-1 justify-content-center">
                    <i class="bi bi-check2-circle me-2"></i> SAVE NEW CATEGORY
                </button>
                <a asp-action="Index" class="btn-discard-premium text-decoration-none">
                    DISCARD
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}



@model IEnumerable<DormMS.Web.Models.Fee>

<div class="container-fluid px-lg-5 mt-5">
    <div class="row align-items-center mb-5">
        <div class="col-md-8">
            <h1 style="color: #312e81; font-weight: 900; font-size: 2.8rem; letter-spacing: -2px; margin: 0;">
                Fee <span style="color: #6366f1;">Structure.</span>
            </h1>
            <p class="text-muted fw-bold mt-2">Configuration of standardized institutional billing categories and rates.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn-premium">
                <i class="bi bi-plus-lg"></i> Add Fee Category
            </a>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="stat-card-new shadow-sm border-0 h-100" style="border-top: 5px solid #6366f1 !important;">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="icon-box icon-blue" style="width: 45px; height: 45px; border-radius: 12px;">
                            <i class="bi bi-calculator-fill"></i>
                        </div>
                        <span class="badge @(item.isRecurring ? "badge-confirmed" : "badge-pending")">
                            @(item.isRecurring ? "Recurring" : "One-Time")
                        </span>
                    </div>

                    <h4 class="fw-900 text-dark mb-1">@item.feeName</h4>
                    <p class="text-muted small fw-bold text-uppercase mb-4">Category: @item.feeCategory</p>

                    <div class="p-3 rounded-4 mb-4" style="background: #f8fafc; border: 1px solid #edf2f7;">
                        <span class="info-label-pro">Standard Rate</span>
                        <div class="fw-900 text-dark fs-3">$@item.amount.ToString("N2")</div>
                    </div>

                    <div class="d-flex gap-2 mt-auto">
                        <!-- Index.cshtml içinde butonu şu şekilde güncelle -->
                        <a asp-action="Edit" asp-route-id="@item.id" class="btn btn-light rounded-pill flex-grow-1 fw-bold small py-2 text-decoration-none text-center">
                            <i class="bi bi-pencil-square me-1"></i> Edit Rate
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@{
    ViewData["Title"] = "Reports Management";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4"><i class="bi bi-file-earmark-bar-graph me-2 text-primary"></i>System Reports</h2>
            <p class="text-muted">Generate and export system reports to CSV/Excel format for manual analysis and archiving.</p>
        </div>
    </div>

    <div class="row mt-3">
        @if (!User.IsInRole("Finance"))
        {
            <!-- Occupancy Report -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body text-center p-4">
                        <div class="display-4 text-success mb-3"><i class="bi bi-door-open"></i></div>
                        <h5 class="card-title">Occupancy Report</h5>
                        <p class="card-text text-muted small">Current room statuses, building occupancy levels, and capacity details.</p>
                        <a asp-action="OccupancyReport" class="btn btn-outline-success w-100 mt-2">
                            <i class="bi bi-download me-1"></i> Export Occupancy
                        </a>
                    </div>
                </div>
            </div>
        }

        <!-- Financial Report -->
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-cash-stack"></i></div>
                    <h5 class="card-title">Financial Report</h5>
                    <p class="card-text text-muted small">Ledger summary including payments, student balances, and transaction history.</p>
                    <a asp-action="FinancialReport" class="btn btn-outline-primary w-100 mt-2">
                        <i class="bi bi-download me-1"></i> Export Financials
                    </a>
                </div>
            </div>
        </div>

        @if (!User.IsInRole("Finance"))
        {
            <!-- Maintenance Report -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body text-center p-4">
                        <div class="display-4 text-warning mb-3"><i class="bi bi-tools"></i></div>
                        <h5 class="card-title">Maintenance Report</h5>
                        <p class="card-text text-muted small">Overview of all maintenance requests, priority levels, and resolution status.</p>
                        <a asp-action="MaintenanceReport" class="btn btn-outline-warning w-100 mt-2">
                            <i class="bi bi-download me-1"></i> Export Maintenance
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

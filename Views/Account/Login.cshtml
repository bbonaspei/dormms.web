@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DormMS - Secure Access</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body class="login-page-body d-flex align-items-center justify-content-center" style="min-height: 100vh;">

    <div class="premium-login-card">

        <!-- Renkli Header (BEYAZLIĞI KIRAN KISIM) -->
        <div class="login-card-header">
            <div style="width: 50px; height: 50px; background: white; border-radius: 14px; display: inline-flex; align-items: center; justify-content: center; color: #6366f1; font-size: 24px; margin-bottom: 15px; box-shadow: 0 8px 20px rgba(0,0,0,0.15);">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2 style="font-weight: 800; letter-spacing: -1px; margin: 0;">Identity Portal</h2>
            <p style="color: rgba(255,255,255,0.7); font-size: 13px; margin-top: 5px;">Secure gateway for DormMS Administration</p>
        </div>

        <!-- Form Body -->
        <div class="login-card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 small fw-bold mb-4" style="border-radius: 10px; background: #fff1f2; color: #e11d48;">
                    <i class="bi bi-x-circle-fill me-2"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <div class="mb-4">
                    <label class="login-label-pro">Account Username</label>
                    <input name="username" type="text" class="login-input-pro" placeholder="e.g. administrator" required />
                </div>

                <div class="mb-4">
                    <label class="login-label-pro">Password Key</label>
                    <input name="password" type="password" class="login-input-pro" placeholder="••••••••" required />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="remember" style="border-color: #cbd5e1;">
                        <label class="form-check-label small fw-semibold text-muted" for="remember">Keep me active</label>
                    </div>
                </div>

                <!-- Küçültülmüş ve Modern Buton -->
                <button type="submit" class="btn-login-pro">
                    Login <i class="bi bi-chevron-right"></i>
                </button>
            </form>

        </div>
    </div>

</body>
</html>
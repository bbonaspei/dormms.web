@model DormMS.Web.Models.User

<div class="container-fluid px-lg-5 mt-4">
    <!-- Sayfa Başlığı -->
    <div class="mb-5">
        <h1 style="color: #6366f1 !important; font-weight: 900; font-size: 2.8rem; letter-spacing: -2px;">
            Settings Center.
        </h1>
        <p class="text-muted fw-bold">Manage your institutional profile, security keys, and system preferences.</p>
    </div>

    <div class="row g-5">
        <!-- SOL MENÜ (Daha sola çekildi ve zenginleştirildi) -->
        <div class="col-xl-3 col-lg-4">
            <div class="settings-sidebar">
                <div class="stat-card-new p-4 shadow-sm border-0">
                    <div class="nav flex-column nav-pills gap-2" id="settingsTab" role="tablist">
                        <button class="settings-nav-pill active" data-bs-toggle="pill" data-bs-target="#profile">
                            <i class="bi bi-person-circle me-2"></i> Account Information
                        </button>
                        <button class="settings-nav-pill" data-bs-toggle="pill" data-bs-target="#security">
                            <i class="bi bi-shield-lock-fill me-2 text-warning"></i> Security & Password
                        </button>
                        <button class="settings-nav-pill" data-bs-toggle="pill" data-bs-target="#notifications">
                            <i class="bi bi-bell-fill me-2 text-primary"></i> Notification Prefs
                        </button>
                        <hr class="my-3 opacity-10">
                        <a asp-action="Logout" class="settings-nav-pill text-danger text-decoration-none">
                            <i class="bi bi-box-arrow-right me-2"></i> Terminate Session
                        </a>
                    </div>
                </div>

                <!-- Alt Bilgi Kutusu (Diğer uygulamalardaki gibi) -->
                <div class="stat-card-new mt-4 p-4 border-0 shadow-sm bg-light">
                    <span class="info-label-pro">Account Type</span>
                    <span class="badge bg-primary rounded-pill px-3 py-2 mt-2">Institutional Administrator</span>
                </div>
            </div>
        </div>

        <!-- SAĞ İÇERİK (Dinamik Sekmeler) -->
        <div class="col-xl-9 col-lg-8">
            <div class="tab-content">

                <!-- 1. PROFİL BİLGİLERİ -->
                <div class="tab-pane fade show active" id="profile">
                    <div class="stat-card-new p-5 shadow-sm border-0">
                        <h3 class="fw-900 text-dark mb-4">Public Profile</h3>
                        <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                            <div class="row g-4">
                                <div class="col-12 mb-4 text-center">
                                    <div class="position-relative d-inline-block">
                                        @if (!string.IsNullOrEmpty(Model.profilePicture))
                                        {
                                            <img id="profilePreview" src="@Model.profilePicture" 
                                                 class="rounded-circle shadow-sm border border-4 border-white" 
                                                 style="width: 150px; height: 150px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div id="profilePreviewContainer" class="rounded-circle shadow-sm border border-4 border-white d-flex align-items-center justify-content-center" 
                                                 style="width: 150px; height: 150px; background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); color: white; font-size: 4rem; font-weight: 900;">
                                                @(Model.firstName?[0].ToString() ?? "U")
                                            </div>
                                            <img id="profilePreview" class="rounded-circle shadow-sm border border-4 border-white d-none" 
                                                 style="width: 150px; height: 150px; object-fit: cover;" />
                                        }
                                        <label for="profilePhoto" class="position-absolute bottom-0 end-0 btn btn-primary btn-sm rounded-circle p-2 shadow" style="cursor: pointer;">
                                            <i class="bi bi-camera-fill"></i>
                                        </label>
                                        <input type="file" id="profilePhoto" name="profilePhoto" class="d-none" accept="image/*" onchange="previewImage(this)" />
                                    </div>
                                    <p class="text-muted small mt-2">Click the camera icon to change photo</p>
                                </div>
                                <div class="col-md-6">
                                    <label class="label-premium">First Name</label>
                                    <input asp-for="firstName" class="dorm-input-premium" />
                                </div>
                                <div class="col-md-6">
                                    <label class="label-premium">Last Name</label>
                                    <input asp-for="lastName" class="dorm-input-premium" />
                                </div>
                                <div class="col-12">
                                    <label class="label-premium">Institutional Email Address</label>
                                    <input asp-for="email" class="dorm-input-premium" />
                                </div>
                                <div class="col-12">
                                    <label class="label-premium">Contact Phone Number</label>
                                    <input asp-for="phone" class="dorm-input-premium" placeholder="+90 5xx..." />
                                </div>
                            </div>
                            <div class="mt-5 pt-3 border-top">
                                <button type="submit" class="btn-premium px-5">Save Profile Changes</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- 2. GÜVENLİK VE ŞİFRE (Eksik olan kısım eklendi) -->
                <div class="tab-pane fade" id="security">
                    <div class="stat-card-new p-5 shadow-sm border-0 border-top border-5 border-warning">
                        <h3 class="fw-900 text-dark mb-1">Security Credentials</h3>
                        <p class="text-muted small fw-bold mb-5">Update your password to keep your account secure.</p>

                        <form asp-action="ChangePassword" method="post" style="max-width: 500px;">
                            <div class="input-wrapper-premium mb-4">
                                <label class="label-premium">Current Password</label>
                                <input name="currentPassword" type="password" class="dorm-input-premium" required />
                            </div>
                            <div class="input-wrapper-premium mb-4">
                                <label class="label-premium">New Secure Password</label>
                                <input name="newPassword" type="password" class="dorm-input-premium" required />
                            </div>
                            <div class="input-wrapper-premium mb-5">
                                <label class="label-premium">Confirm New Password</label>
                                <input type="password" class="dorm-input-premium" required />
                            </div>
                            <button type="submit" class="btn-premium w-100 py-3" style="background:#f59e0b !important;">
                                <i class="bi bi-shield-lock me-2"></i> Update Security Key
                            </button>
                        </form>
                    </div>
                </div>

                <!-- 3. BİLDİRİM TERCİHLERİ (Görsel doluluk için) -->
                <div class="tab-pane fade" id="notifications">
                    <div class="stat-card-new p-5 shadow-sm border-0">
                        <h3 class="fw-900 text-dark mb-4">Email Preferences</h3>
                        <div class="d-flex flex-column gap-4">
                            <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-4">
                                <div>
                                    <h6 class="fw-bold mb-0">Financial Alerts</h6>
                                    <small class="text-muted">Receive emails about unpaid student dues.</small>
                                </div>
                                <div class="form-check form-switch"><input class="form-check-input" type="checkbox" checked></div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-4">
                                <div>
                                    <h6 class="fw-bold mb-0">Maintenance Updates</h6>
                                    <small class="text-muted">Get notified when an issue is assigned to staff.</small>
                                </div>
                                <div class="form-check form-switch"><input class="form-check-input" type="checkbox"></div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    var preview = document.getElementById('profilePreview');
                    var container = document.getElementById('profilePreviewContainer');
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                    if (container) container.classList.add('d-none');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
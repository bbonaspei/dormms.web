@model DormMS.Web.Models.User
@{
    ViewData["Title"] = "Staff Profile";
}

<div class="container-fluid px-4 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- PROFILE HEADER -->
            <div class="profile-header-premium shadow-sm mb-5">
                <div class="d-flex align-items-center gap-4 flex-wrap">
                    <div class="avatar-main-wrapper shadow-sm">
                        @if (!string.IsNullOrEmpty(Model.profilePicture))
                        {
                            <img src="@Model.profilePicture" style="width:100%; height:100%; object-fit:cover;" />
                        }
                        else
                        {
                            @(Model.firstName?[0])@(Model.lastName?[0])
                        }
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <h1 class="fw-900 text-dark m-0" style="font-size: 2.5rem; letter-spacing: -1.5px;">@Model.firstName @Model.lastName</h1>
                            <span class="badge bg-primary rounded-pill px-3 py-1 fw-bold" style="font-size: 10px;">INSTITUTIONAL STAFF</span>
                        </div>
                        <div class="text-muted fw-bold d-flex gap-3 align-items-center">
                            <span><i class="bi bi-envelope-fill text-primary"></i> @Model.email</span>
                            <span class="opacity-25">|</span>
                            <span><i class="bi bi-person-badge-fill text-primary"></i> Resource Managed Account</span>
                        </div>
                    </div>
                    <div class="ms-md-auto">
                        <a asp-action="Settings" class="btn btn-outline-primary fw-bold rounded-pill px-4">
                            <i class="bi bi-gear-fill me-2"></i> Account Settings
                        </a>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- ACC REDENTIALS -->
                <div class="col-md-5">
                    <div class="info-section-card shadow-sm h-100">
                        <h6 class="section-title-premium"><i class="bi bi-shield-lock-fill"></i> ACCOUNT DETAILS</h6>
                        
                        <div class="info-box-premium">
                            <label class="info-label-pro">Username</label>
                            <span class="info-value-pro">@Model.username</span>
                        </div>
                        
                        <div class="info-box-premium">
                            <label class="info-label-pro">Direct Contact</label>
                            <span class="info-value-pro">@(Model.phone ?? "Not Provided")</span>
                        </div>

                        <div class="info-box-premium border-dashed bg-transparent mt-4">
                            <label class="info-label-pro">Access Level</label>
                            <span class="info-value-pro text-primary"><i class="bi bi-check-circle-fill me-1"></i> Facility Operations</span>
                            <span class="info-value-pro text-primary"><i class="bi bi-check-circle-fill me-1"></i> Maintenance Execution</span>
                        </div>
                    </div>
                </div>

                <!-- STAFF METRICS / QUICK INFO -->
                <div class="col-md-7">
                    <div class="info-section-card shadow-sm h-100 bg-glass-dark">
                        <h6 class="section-title-premium"><i class="bi bi-bar-chart-fill text-warning"></i> OPERATIONAL METRICS</h6>
                        
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="stat-card-new alert-border-blue py-3 px-3">
                                    <div class="small fw-bold text-muted mb-1">Status</div>
                                    <div class="fw-900 text-primary">Active Duty</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card-new alert-border-green py-3 px-3">
                                    <div class="small fw-bold text-muted mb-1">Shift</div>
                                    <div class="fw-900 text-success">Main Facility</div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 p-4 rounded-4 bg-white shadow-sm border">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-box icon-blue">
                                    <i class="bi bi-info-circle"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold m-0 text-dark">System Authorization</h6>
                                    <p class="small text-muted m-0">You are authorized to fulfill maintenance requests and manage facility assets assigned to your profile.</p>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 text-center">
                            <p class="small text-muted">Internal ID: @Model.Id</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@model DormMS.Web.Models.User
@{
    ViewData["Title"] = "Staff Profile";
}

<div class="container-fluid px-4 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            
            <div class="profile-header-premium shadow-sm mb-5">
                <div class="d-flex align-items-center gap-4 flex-wrap">
                    <div class="avatar-main-wrapper shadow-sm">
                        @if (!string.IsNullOrEmpty(Model.profilePicture))
                        {
                            <img src="@Model.profilePicture" style="width:100%; height:100%; object-fit:cover;" />
                        }
                        else
                        {
                            @(Model.firstName?[0])@(Model.lastName?[0])
                        }
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <h1 class="fw-900 text-dark m-0" style="font-size: 2.5rem; letter-spacing: -1.5px;">@Model.firstName @Model.lastName</h1>
                            @{
                                var roleName = "Institutional User";
                                var badgeClass = "bg-primary";
                                if (User.IsInRole("Admin")) { roleName = "System Administrator"; badgeClass = "bg-danger"; }
                                else if (User.IsInRole("Finance")) { roleName = "Finance Officer"; badgeClass = "bg-success"; }
                                else if (User.IsInRole("Staff")) { roleName = "Operations Staff"; badgeClass = "bg-warning text-dark"; }
                                else if (User.IsInRole("Manager") || User.IsInRole("DormManager")) { roleName = "Dormitory Manager"; badgeClass = "bg-info text-white"; }
                            }
                            <span class="badge @badgeClass rounded-pill px-3 py-1 fw-bold" style="font-size: 10px;">@roleName.ToUpper()</span>
                        </div>
                        <div class="text-muted fw-bold d-flex gap-3 align-items-center">
                            <span><i class="bi bi-envelope-fill text-primary"></i> @Model.email</span>
                            <span class="opacity-25">|</span>
                            <span><i class="bi bi-shield-check-fill text-primary"></i> Secured Institutional Account</span>
                        </div>
                    </div>
                    <div class="ms-md-auto">
                        <a asp-action="Settings" class="btn btn-outline-primary fw-bold rounded-pill px-4">
                            <i class="bi bi-gear-fill me-2"></i> Account Settings
                        </a>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                
                <div class="col-md-5">
                    <div class="info-section-card shadow-sm h-100">
                        <h6 class="section-title-premium"><i class="bi bi-shield-lock-fill"></i> ACCOUNT DETAILS</h6>
                        
                        <div class="info-box-premium">
                            <label class="info-label-pro">Username</label>
                            <span class="info-value-pro">@Model.username</span>
                        </div>
                        
                        <div class="info-box-premium">
                            <label class="info-label-pro">Direct Contact</label>
                            <span class="info-value-pro">@(Model.phone ?? "Not Provided")</span>
                        </div>

                        <div class="info-box-premium border-dashed bg-transparent mt-4">
                            <label class="info-label-pro">Access Level & Roles</label>
                            @if (User.IsInRole("Admin")) { 
                                <span class="info-value-pro text-danger"><i class="bi bi-key-fill me-1"></i> Root Administrator</span> 
                                <span class="info-value-pro text-danger"><i class="bi bi-shield-lock-fill me-1"></i> System Logic Control</span> 
                            }
                            else if (User.IsInRole("Finance")) { 
                                <span class="info-value-pro text-success"><i class="bi bi-cash-coin me-1"></i> Revenue Management</span> 
                                <span class="info-value-pro text-success"><i class="bi bi-bar-chart-fill me-1"></i> Financial Reporting</span> 
                            }
                            else {
                                <span class="info-value-pro text-primary"><i class="bi bi-check-circle-fill me-1"></i> Facility Operations</span>
                                <span class="info-value-pro text-primary"><i class="bi bi-check-circle-fill me-1"></i> Maintenance Execution</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-7">
                    <div class="info-section-card shadow-sm h-100 bg-glass-dark">
                        <h6 class="section-title-premium"><i class="bi bi-bar-chart-fill text-warning"></i> OPERATIONAL METRICS</h6>
                        
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="stat-card-new alert-border-blue py-3 px-3">
                                    <div class="small fw-bold text-muted mb-1">Account Status</div>
                                    <div class="fw-900 text-primary">@(Model.isActive ? "Active Duty" : "Deactivated")</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card-new alert-border-green py-3 px-3">
                                    <div class="small fw-bold text-muted mb-1">Shift / Duty</div>
                                    <div class="fw-900 text-success">Main Facility</div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 p-4 rounded-4 bg-white shadow-sm border">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-box icon-blue">
                                    <i class="bi bi-info-circle"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold m-0 text-dark">System Authorization</h6>
                                    @{
                                        var authText = "You are authorized to manage facility operations.";
                                        if (User.IsInRole("Admin")) authText = "Full system control authorized. You can manage users, room inventory, and financial structures.";
                                        else if (User.IsInRole("Finance")) authText = "Financial authorization granted. You can sync ledgers, manage fees, and process payment records.";
                                        else if (User.IsInRole("Staff")) authText = "Operational authorization granted. You can manage maintenance requests and facility updates.";
                                    }
                                    <p class="small text-muted m-0">@authText</p>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 text-center">
                            <p class="small text-muted">Internal ID: @Model.Id</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>




<div class="container mt-5">
    <div class="stat-card-new p-5 shadow-sm border-top border-5 border-primary" style="max-width: 500px; margin: 0 auto;">
        <h3 class="fw-900 text-dark mb-4">Security <span class="text-primary">Settings</span></h3>
        <form asp-action="ChangePassword" method="post">
            <div class="input-wrapper-premium mb-3">
                <label class="label-premium">Current Password</label>
                <input name="currentPassword" type="password" class="dorm-input-premium" required />
            </div>
            <div class="input-wrapper-premium mb-4">
                <label class="label-premium">New Password</label>
                <input name="newPassword" type="password" class="dorm-input-premium" required />
            </div>
            <button type="submit" class="btn-premium w-100 py-3">UPDATE SECURITY KEY</button>
        </form>
    </div>
</div>



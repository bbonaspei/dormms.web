<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DormMS - Control Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css?v=@DateTime.Now.Ticks">
    <link rel="stylesheet" href="~/css/layout.css?v=@DateTime.Now.Ticks">
    <link rel="stylesheet" href="~/css/components.css?v=@DateTime.Now.Ticks">
</head>
<body>
    @* SİSTEMİN HANGİ SAYFADA OLDUĞUNU ANLAYAN MANTIK *@
    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    <div class="mesh-bg">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom sticky-top">
        <div class="container-fluid px-4">
            <!-- LOGO: Landing Page'e gidecek -->
            <a class="brand-wrapper text-decoration-none" asp-controller="Home" asp-action="Landing">
                <div class="logo-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                <div class="brand-text">DormMS</div>
            </a>

            <div class="collapse navbar-collapse ms-5">
                <ul class="navbar-nav gap-1">

                    <!-- DASHBOARD -->
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                            Dashboard
                        </a>
                    </li>

                    <!-- HOUSING GROUP -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(currentController == "Rooms" || currentController == "Buildings" || currentController == "RoomTypes" || currentController == "Allocations" ? "active" : "")"
                           href="#" data-bs-toggle="dropdown">Housing</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Rooms" asp-action="Index"><i class="bi bi-door-open-fill me-2"></i> Room Inventory</a></li>
                            <li><a class="dropdown-item" asp-controller="Buildings" asp-action="Index"><i class="bi bi-building-fill me-2"></i> Buildings</a></li>
                            <li><a class="dropdown-item" asp-controller="RoomTypes" asp-action="Index"><i class="bi bi-tags-fill me-2"></i> Room Classifications</a></li>
                            <li><a class="dropdown-item" asp-controller="Allocations" asp-action="Index"><i class="bi bi-key-fill me-2"></i> Allocations</a></li>
                        </ul>
                    </li>

                    <!-- STUDENTS GROUP -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(currentController == "Students" ? "active" : "")"
                           href="#" data-bs-toggle="dropdown">Students</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Students" asp-action="Index"><i class="bi bi-people-fill me-2"></i> Student Directory</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-file-earmark-text-fill me-2"></i> Documents</a></li>
                        </ul>
                    </li>

                    <!-- FINANCIAL GROUP -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(currentController == "Payments" || currentController == "Fees" ? "active" : "")"
                           href="#" data-bs-toggle="dropdown">Financial</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Payments" asp-action="Index"><i class="bi bi-cash-stack me-2"></i> Payment Ledger</a></li>
                            <li><a class="dropdown-item" asp-controller="Fees" asp-action="Index"><i class="bi bi-calculator-fill me-2"></i> Fee Structure</a></li>
                        </ul>
                    </li>

                    <!-- MAINTENANCE -->
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Maintenance" ? "active" : "")" asp-controller="Maintenance" asp-action="Index">
                            Maintenance
                        </a>
                    </li>

                    <!-- SYSTEM GROUP -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(currentController == "Audit" ? "active" : "")"
                           href="#" data-bs-toggle="dropdown">System</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Audit" asp-action="Index"><i class="bi bi-shield-lock-fill me-2"></i> Audit Telemetry</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-gear-fill me-2"></i> Global Settings</a></li>
                        </ul>
                    </li>
                </ul>
            </div>

            <!-- SAĞ ÜST İKONLAR GRUBU (TEMİZLENDİ VE HATALARI GİDERİLDİ) -->
            <div class="d-flex align-items-center gap-2">

                <!-- 1. AYARLAR İKONU -->
                <i class="bi bi-gear header-action-icon" title="Settings"></i>

                <!-- 2. BİLDİRİM PANELİ -->
                <div class="dropdown">
                    <div class="header-action-icon circle-hover position-relative" data-bs-toggle="dropdown" style="cursor:pointer;">
                        <i class="bi bi-bell"></i>
                        <span class="pulse-badge"></span>
                    </div>

                    <div class="dropdown-menu dropdown-menu-end dropdown-menu-premium">
                        <div class="notif-header d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-dark">Notifications</span>
                            <span class="badge bg-primary-subtle text-primary rounded-pill px-2" style="font-size:10px;">2 New</span>
                        </div>

                        <div class="notif-list">
                            <a class="dropdown-item notif-item" href="#">
                                <div class="notif-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                                    <i class="bi bi-check-circle-fill"></i>
                                </div>
                                <div style="flex:1">
                                    <div class="small fw-bold text-dark">Payment Success</div>
                                    <div class="small text-muted text-wrap" style="font-size: 11px;">Verification successful for student #105.</div>
                                </div>
                            </a>
                            <a class="dropdown-item notif-item" href="#">
                                <div class="notif-icon" style="background: rgba(244, 63, 94, 0.1); color: #f43f5e;">
                                    <i class="bi bi-tools"></i>
                                </div>
                                <div style="flex:1">
                                    <div class="small fw-bold text-dark">Maintenance Alert</div>
                                    <div class="small text-muted text-wrap" style="font-size: 11px;">Plumbing issue reported in Room 204.</div>
                                </div>
                            </a>
                        </div>

                        <a href="#" class="dropdown-item text-center py-3 small fw-bold text-primary border-0" style="background: #f8fafc;">
                            View All Inbox
                        </a>
                    </div>
                </div>

                <!-- 3. PROFİL BUTONU -->
                <!-- _Layout.cshtml içindeki Avatar linkini bul ve düzelt -->
                <a asp-controller="Students" asp-action="Details" asp-route-id="1" class="user-avatar-btn ms-2 text-decoration-none">
                    AU
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-5 mt-4">
        <main role="main">@RenderBody()</main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DormMS - Intelligence Systems</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css?v=@DateTime.Now.Ticks">
    <link rel="stylesheet" href="~/css/layout.css?v=@DateTime.Now.Ticks">
    <link rel="stylesheet" href="~/css/components.css?v=@DateTime.Now.Ticks">
    <!-- SweetAlert2 CSS & JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    @* Sayfa tespiti *@
    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    <div class="mesh-bg">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom sticky-top">
        <div class="container-fluid px-4">

            <!-- MOBİL İÇİN MENÜ BUTONU (solda) -->
            <button class="navbar-toggler border-0 shadow-none d-lg-none order-1" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileOffcanvasMenu" aria-label="Menüyü Aç">
                <i class="bi bi-list text-white fs-2"></i>
            </button>

            <!-- LOGO: ortada mobil, solda masaüstü -->
            <a class="brand-wrapper text-decoration-none order-2 mx-auto mx-lg-0" asp-controller="Home" asp-action="Landing">
                <div class="logo-icon bg-white" style="color: #6366f1;"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                <div class="brand-text">DormMS</div>
            </a>

            <!-- MASAÜSTÜ MENÜ -->
            <div class="collapse navbar-collapse ms-5 d-none d-lg-flex order-3">
                <ul class="navbar-nav gap-1">

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                            @if (User.IsInRole("Student")) { <text>Dashboard</text> }
                            else if (User.IsInRole("Staff") && !User.IsInRole("Admin")) { <text>Operations Hub</text> }
                            else if (User.IsInRole("Finance")) { <text>Dashboard</text> }
                            else { <text>Analytics</text> }
                        </a>
                    </li>

                    @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("DormManager"))
                    {
                            <!-- HOUSING -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(currentController == "Rooms" || currentController == "Buildings" || currentController == "Allocations" ? "active" : "")"
                                   href="#" data-bs-toggle="dropdown">Housing</a>
                                <ul class="dropdown-menu border-0 shadow-lg mt-3">
                                    <li><a class="dropdown-item py-2" asp-controller="Rooms" asp-action="Index"><i class="bi bi-door-open-fill me-2 text-primary"></i> Room Inventory</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Buildings" asp-action="Index"><i class="bi bi-building-fill me-2 text-primary"></i> Buildings</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Allocations" asp-action="Index"><i class="bi bi-key-fill me-2 text-primary"></i> Live Placements</a></li>
                                </ul>
                            </li>

                            <!-- RESIDENTS -->
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Students" ? "active" : "")" asp-controller="Students" asp-action="Index">Residents</a>
                            </li>
                        }

                        @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("DormManager"))
                        {
                            <!-- REPORTS -->
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Reports" ? "active" : "")" asp-controller="Reports" asp-action="Index">Reports</a>
                            </li>
                        }

                        @if (!User.IsInRole("Staff") || User.IsInRole("Finance"))
                        {
                            <!-- FINANCIAL -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(currentController == "Payments" || currentController == "Fees" ? "active" : "")"
                                   href="#" data-bs-toggle="dropdown">@(User.IsInRole("Student") ? "My Finances" : "Financial Operations")</a>
                                <ul class="dropdown-menu border-0 shadow-lg mt-3">
                                    <li><a class="dropdown-item py-2" asp-controller="Payments" asp-action="Index"><i class="bi bi-cash-stack me-2 text-success"></i> @(User.IsInRole("Student") ? "My Ledger" : "Revenue Ledger")</a></li>

                                    @if (User.IsInRole("Admin") || User.IsInRole("Finance"))
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="Fees" asp-action="Index"><i class="bi bi-calculator-fill me-2 text-success"></i> Fee Structure</a></li>
                                    }
                                </ul>
                            </li>
                        }


                    <!-- MAINTENANCE (Finance hariç herkes görebilir) -->
                    @if (!User.IsInRole("Finance"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Maintenance" ? "active" : "")" asp-controller="Maintenance" asp-action="Index">
                                @(User.IsInRole("Student") ? "Fix-It Requests" : "Operations")
                            </a>
                        </li>
                    }

                    <!-- SYSTEM (Sadece Admin) -->
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Audit" ? "active" : "")" asp-controller="Audit" asp-action="Index">Audit Logs</a>
                        </li>
                    }
                </ul>
            </div>

            <!-- SAĞ ÜST İKONLAR VE PROFİL (sağda, order-4) -->
            <div class="d-flex align-items-center gap-2 ms-auto order-4">

                <!-- BİLDİRİM PANELİ -->
                <div class="dropdown">
                    <div class="header-action-icon circle-hover position-relative" data-bs-toggle="dropdown" style="cursor:pointer;" onclick="loadNotifications()">
                        <i class="bi bi-bell"></i>
                        <span id="notifBadge" class="pulse-badge d-none"></span>
                    </div>

                    <div class="dropdown-menu dropdown-menu-end dropdown-menu-premium mt-3">
                        <div class="notif-header d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-dark">System Alerts</span>
                            <span id="notifCount" class="badge bg-primary text-white rounded-pill px-2" style="font-size:10px;">0</span>
                        </div>
                        <div id="notificationContainer" class="notif-list">
                            <div class="p-4 text-center small text-muted">No new notifications.</div>
                        </div>
                    </div>
                </div>

                <!-- PROFİL DROPDOWN -->
                <div class="dropdown">
                    <div class="user-avatar-btn ms-2 shadow-sm d-flex align-items-center justify-content-center overflow-hidden" data-bs-toggle="dropdown" style="cursor:pointer;">
                        @if (User.HasClaim(c => c.Type == "ProfilePicture") && !string.IsNullOrEmpty(User.FindFirst("ProfilePicture")?.Value))
                        {
                            <img src="@User.FindFirst("ProfilePicture")?.Value" style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "U")
                        }
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-3" style="border-radius: 20px; min-width: 200px;">
                        <li class="px-3 py-2 border-bottom mb-2">
                            <div class="fw-bold text-dark small">@(User.Identity?.Name ?? "User")</div>
                            <div class="text-muted" style="font-size: 10px;">@(User.IsInRole("Student") ? "Resident Portal" : "Institutional Account")</div>
                        </li>
                        <li><a class="dropdown-item py-2 small fw-bold" asp-controller="Account" asp-action="MyProfile"><i class="bi bi-person me-2"></i> My Profile</a></li>

                        <li><a class="dropdown-item py-2 small fw-bold" asp-controller="Account" asp-action="Settings"><i class="bi bi-gear me-2"></i> System Settings</a></li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li><a class="dropdown-item py-2 small fw-bold text-primary" asp-controller="Staff" asp-action="Index"><i class="bi bi-people me-2"></i> Manage Workers</a></li>
                        }

                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item py-2 small fw-bold text-danger" asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-2"></i> Terminate Session
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- MOBİL YANDAN MENÜ (YETKİ KONTROLÜ EKLENDİ) -->
    <div class="offcanvas offcanvas-start offcanvas-premium" tabindex="-1" id="mobileOffcanvasMenu">
        <div class="offcanvas-header border-bottom border-white-50">
            <div class="d-flex align-items-center gap-2">
                <div class="logo-icon bg-white" style="color:#6366f1;"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                <h5 class="offcanvas-title text-white fw-bold m-0">Control Center</h5>
            </div>
            <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body px-0 pt-0">
            <ul class="navbar-nav px-3 gap-2">
                <!-- DASHBOARD -->
                <li class="nav-item">
                    <a class="nav-link text-white @(currentController == "Home" ? "fw-bold active" : "")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i>
                        @if (User.IsInRole("Student")) { <text>Dashboard</text> }
                        else if (User.IsInRole("Staff") && !User.IsInRole("Admin")) { <text>Operations Hub</text> }
                        else if (User.IsInRole("Finance")) { <text>Dashboard</text> }
                        else { <text>Analytics</text> }
                    </a>
                </li>

                @if (!User.IsInRole("Staff"))
                {
                    @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("DormManager"))
                    {
                        @if (!User.IsInRole("Finance"))
                        {
                            <!-- HOUSING SECTION -->
                            <div class="small fw-bold text-white-50 px-3 mt-3 mb-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1.2px;">Housing</div>
                            <li class="nav-item"><a class="nav-link text-white @(currentController == "Rooms" ? "fw-bold active" : "")" asp-controller="Rooms" asp-action="Index"><i class="bi bi-door-open-fill me-2"></i>Room Inventory</a></li>
                            <li class="nav-item"><a class="nav-link text-white @(currentController == "Buildings" ? "fw-bold active" : "")" asp-controller="Buildings" asp-action="Index"><i class="bi bi-building-fill me-2"></i>Buildings</a></li>
                            <li class="nav-item"><a class="nav-link text-white @(currentController == "Allocations" ? "fw-bold active" : "")" asp-controller="Allocations" asp-action="Index"><i class="bi bi-key-fill me-2"></i>Live Placements</a></li>

                            <!-- RESIDENTS SECTION -->
                            <div class="small fw-bold text-white-50 px-3 mt-3 mb-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1.2px;">People</div>
                            <li class="nav-item"><a class="nav-link text-white @(currentController == "Students" ? "fw-bold active" : "")" asp-controller="Students" asp-action="Index"><i class="bi bi-people-fill me-2"></i>Residents</a></li>
                        }
                        
                        <li class="nav-item">
                            <a class="nav-link text-white @(currentController == "Reports" ? "fw-bold active" : "")" asp-controller="Reports" asp-action="Index">
                                <i class="bi bi-file-earmark-bar-graph me-2"></i>Reports
                            </a>
                        </li>
                    }

                    <!-- FINANCIAL SECTION -->
                    <div class="small fw-bold text-white-50 px-3 mt-3 mb-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1.2px;">Financial</div>
                    <li class="nav-item">
                        <a class="nav-link text-white @(currentController == "Payments" ? "fw-bold active" : "")" asp-controller="Payments" asp-action="Index">
                            <i class="bi bi-cash-stack me-2"></i>@(User.IsInRole("Student") ? "My Ledger" : "Revenue Ledger")
                        </a>
                    </li>
                    @if (User.IsInRole("Admin") || User.IsInRole("Finance"))
                    {
                        <li class="nav-item"><a class="nav-link text-white @(currentController == "Fees" ? "fw-bold active" : "")" asp-controller="Fees" asp-action="Index"><i class="bi bi-calculator-fill me-2"></i>Fee Structure</a></li>
                    }
                }

                @if (!User.IsInRole("Finance"))
                {
                    <!-- MAINTENANCE SECTION -->
                    <div class="small fw-bold text-white-50 px-3 mt-3 mb-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1.2px;">Operations</div>
                    <li class="nav-item">
                        <a class="nav-link text-white @(currentController == "Maintenance" ? "fw-bold active" : "")" asp-controller="Maintenance" asp-action="Index">
                            <i class="bi bi-tools me-2"></i>@(User.IsInRole("Student") ? "Fix-It Requests" : "Operations Hub")
                        </a>
                    </li>
                }

                <!-- SYSTEM SECTION (Sadece Admin) -->
                @if (User.IsInRole("Admin"))
                {
                    <div class="small fw-bold text-white-50 px-3 mt-3 mb-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1.2px;">System</div>
                    <li class="nav-item"><a class="nav-link text-white @(currentController == "Staff" ? "fw-bold active" : "")" asp-controller="Staff" asp-action="Index"><i class="bi bi-people me-2"></i>Manage Workers</a></li>
                    <li class="nav-item"><a class="nav-link text-white @(currentController == "Audit" ? "fw-bold active" : "")" asp-controller="Audit" asp-action="Index"><i class="bi bi-shield-check me-2"></i>Audit Logs</a></li>
                }

                <!-- ACCOUNT SECTION -->
                <div class="small fw-bold text-white-50 px-3 mt-3 mb-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1.2px;">Account</div>
                <li class="nav-item"><a class="nav-link text-white @(currentController == "Account" && ViewContext.RouteData.Values["Action"]?.ToString() == "MyProfile" ? "fw-bold active" : "")" asp-controller="Account" asp-action="MyProfile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                <li class="nav-item"><a class="nav-link text-white @(currentController == "Account" && ViewContext.RouteData.Values["Action"]?.ToString() == "Settings" ? "fw-bold active" : "")" asp-controller="Account" asp-action="Settings"><i class="bi bi-gear me-2"></i>Settings</a></li>

                <li class="nav-item mt-4 border-top border-white-25 pt-4">
                    <a class="nav-link text-danger fw-bold" asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-2"></i>Terminate Session
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="container-fluid px-lg-5 px-3 mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function loadNotifications() {
            fetch('/Home/GetMyNotifications')
                .then(res => res.json())
                .then(data => {
                    const container = document.getElementById('notificationContainer');
                    const badge = document.getElementById('notifBadge');
                    const count = document.getElementById('notifCount');

                    if (data.length > 0) {
                        badge.classList.remove('d-none');
                        count.innerText = data.length;
                        container.innerHTML = data.map(n => `
                            <div class="notif-item" onclick="markAsRead(${n.id}, '${n.targetUrl || '#'}')">
                                <div class="notif-icon" style="background: rgba(99,102,241,0.1); color:#6366f1;">
                                    <i class="bi bi-info-circle-fill"></i>
                                </div>
                                <div style="flex:1">
                                    <div class="small fw-bold text-dark">${n.title}</div>
                                    <div class="small text-muted text-wrap" style="font-size: 11px;">${n.message}</div>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        badge.classList.add('d-none');
                        count.innerText = "0";
                        container.innerHTML = '<div class="p-4 text-center small text-muted">No new notifications.</div>';
                    }
                });
        }
        function markAsRead(id, targetUrl) {
            fetch(`/Home/MarkNotificationAsRead?id=${id}`, { method: 'POST' })
                .then(() => {
                    if (targetUrl && targetUrl !== '#') {
                        window.location.href = targetUrl;
                    } else {
                        loadNotifications();
                    }
                });
        }
        setInterval(loadNotifications, 30000);
        document.addEventListener('DOMContentLoaded', loadNotifications);
    </script>
    <script>
        // Global notification system for TempData
        document.addEventListener('DOMContentLoaded', function() {
            var success = '@(TempData["Success"] != null ? Html.Raw(TempData["Success"]?.ToString()?.Replace("'", "\\'")) : "")';
            var error = '@(TempData["Error"] != null ? Html.Raw(TempData["Error"]?.ToString()?.Replace("'", "\\'")) : "")';
            
            if (success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: success,
                    timer: 3000,
                    showConfirmButton: false,
                    background: 'rgba(255, 255, 255, 0.9)',
                    backdrop: `rgba(0,0,123,0.1)`
                });
            }
            if (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Operation Failed',
                    text: error,
                    background: 'rgba(255, 255, 255, 0.9)',
                    backdrop: `rgba(123,0,0,0.1)`
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>